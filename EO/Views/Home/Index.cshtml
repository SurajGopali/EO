@model EO.Models.HomeDashboardModel


@{
    ViewData["Title"] = "Home";
}


<link href="~/css/homepage.css" rel="stylesheet">

  <div class="page-header">
    <div class="greeting-block">
      <div class="greeting-sub">Welcome back</div>
      <div class="greeting-name">Good morning, Alex 👋</div>
      <div class="greeting-date" id="liveDate"></div>
      
  </div>
  <div class="weather-block">
        <div class="weather-icon">☀️</div>
        <div class="weather-info">
          <div class="temp-row">
            <span class="temp-val">24°C</span>
            <span class="temp-desc">Sunny</span>
          </div>
      <div class="weather-loc">Lalitpur, Nepal</div>
    </div>
    </div>
    <div style="display:flex;align-items:flex-start;gap:12px;flex-wrap:wrap">
      <div class="stats-row" id="statsRow"></div>
    </div>
  </div>

  <div class="content-grid" id="contentGrid">
    <div class="left-col" id="leftCol">
      <div class="section-hdr">
        <div class="section-title">Upcoming Events</div>
      </div>
      <div class="events-grid" id="eventsList"></div>
       <!-- What's Ahead -->
  <div class="whats-ahead-section">
    <div class="section-hdr">
      <div class="section-title mt-5">What's Ahead</div>
    </div>
    <div class="ahead-grid" id="whatsAhead"></div>
  </div>

    </div>
    <div class="right-col" id="rightCol">
      <!-- Birthdays -->
     <div class="panel">
  <div class="section-hdr">
    <div class="section-title">Birthdays 🎂</div>
    <span class="section-link" onclick="showModal(DATA.birthdays, 'Birthdays')">See all</span>
  </div>

  <div class="carousel-wrap">
    <button class="c-arrow left" id="bdayPrev">
  <i class="bi bi-chevron-left"></i>
</button>

    <div class="c-overflow">
      <div class="c-track" id="bdayTrack"></div>
    </div>

    <button class="c-arrow right" id="bdayNext">
  <i class="bi bi-chevron-right"></i>
</button>

  </div>

  <div class="c-dots" id="bdayDots"></div>
</div>
      <!-- New in Circle -->
     <div class="panel">
  <div class="section-hdr">
    <div class="section-title">New in Circle ✨</div>
    <span class="section-link"  onclick="showModal(DATA.newMembers, 'New Members')">See all</span>
  </div>

  <div class="carousel-wrap">

    <button class="c-arrow left" id="membersPrev">
      <i class="bi bi-chevron-left"></i>
    </button>

    <div class="c-overflow">
      <div class="m-track" id="membersTrack"></div>
    </div>

    <button class="c-arrow right" id="membersNext">
      <i class="bi bi-chevron-right"></i>
    </button>

  </div>

  <div class="c-dots" id="memberDots"></div>
</div>
<!-- Anniversaries -->
<div class="panel">
  <div class="section-hdr">
    <div class="section-title">Anniversaries 🎊</div>
    <span class="section-link" onclick="showModal(DATA.anniversaries, 'Anniversaries')">See all</span>
  </div>

  <div class="carousel-wrap">
    <button class="c-arrow left" id="anniPrev">
      <i class="bi bi-chevron-left"></i>
    </button>

    <div class="c-overflow">
      <div class="c-track" id="anniTrack"></div>
    </div>

    <button class="c-arrow right" id="anniNext">
      <i class="bi bi-chevron-right"></i>
    </button>
  </div>

  <div class="c-dots" id="anniDots"></div>
</div>
    </div>
  </div>


<script>



// ── Dynamic data from HomeDashboardModel (camelCase JSON) ──
const _opts = new Proxy({}, {});
const _rawEvents    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UpcomingEvents,    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
const _rawBirthdays = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UpcomingBirthdays, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
const _rawMembers   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NewMembers,        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
const _rawAhead     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TodayEvents,       new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
const _rawAnniversaries = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.UpcomingAnniversaries, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

// Helper: format a C# TimeSpan string ("HH:MM:SS") → "H:MM AM/PM"
function fmtTime(ts) {
  if (!ts) return 'TBD';
  const [h, m] = ts.split(':').map(Number);
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12  = h % 12 || 12;
  return `${h12}:${String(m).padStart(2,'0')} ${ampm}`;
}

const DATA = {

  stats: [
    { num: _rawEvents.length, label: "Events This Month" },
    { num: _rawEvents.filter(e => e.isRegistered).length,     label: "Registered" }
  ],

  // UpcomingEvents (EventDto) → event cards
  events: _rawEvents.map(e => {
    const d     = new Date(e.date);
    const isReg = e.isRegistered ?? false;
    return {
      title:    e.title    || 'Untitled Event',
      desc:     e.description || '',
      date:     d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      time:     fmtTime(e.startTime),
      days:     e.remainingDays ?? 0,
      location: e.location || 'TBD',
      status:   isReg ? 'Registered' : 'Open',
      badge:    isReg ? 'badge-green' : 'badge-orange',
      reg:      !isReg,
      img:      e.image || 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=700&h=420&fit=crop'
    };
  }),

  // UpcomingBirthdays (BirthdayDto) → birthday carousel
  birthdays: _rawBirthdays.map(b => {
    const dob = new Date(b.dateOfBirth);
    return {
      name:   b.fullName    || 'Member',
      role:   b.designation || '',
      date:   dob.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      avatar: b.profileImage || 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=120&h=120&fit=crop&crop=face'
    };
  }),

  // TodayEvents (EventDto) → What's Ahead
  whatsAhead: _rawAhead.map(e => {
    const d = new Date(e.date);
    return {
      day:   String(d.getDate()).padStart(2, '0'),
      month: d.toLocaleDateString('en-US', { month: 'short' }),
      title: e.title    || 'Event',
      sub:   (e.location || 'TBD') + (e.startTime ? ' · ' + fmtTime(e.startTime) : ''),
      tag:   e.type     || 'Event'
    };
  }),

  anniversaries: _rawAnniversaries.map(a => {
    const joined = new Date(a.anniversaryDate);
    return {
      name:   a.fullName    || 'Member',
      role:   a.designation || '',
      date:   joined.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      years:  a.yearsCompleted || 0,
      avatar: a.profileImage || 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&crop=face'
    };
  }),

  // NewMembers (NewMemberDto) → New in Circle carousel
  newMembers: _rawMembers.map(m => {
    const j = new Date(m.joinedDate);
    return {
      name:   m.fullName    || 'Member',
      role:   m.designation || m.companyName || '',
      joined: 'Joined ' + j.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
      avatar: m.profileImage || 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=120&h=120&fit=crop&crop=face'
    };
  })
};

/* ── DATE ── */
document.getElementById('liveDate').textContent =
  new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

/* ── STATS ── */
document.getElementById('statsRow').innerHTML = DATA.stats.map(s=>
`<div class="stat-card">
    <div class="stat-num">${s.num}</div>
    <div class="stat-label">${s.label}</div>
  </div>`).join('');

/* ── EVENTS ── */
if (DATA.events.length === 0) {
  document.getElementById('eventsList').innerHTML =
    `<div style="text-align:center;">
    <img 
        src="/assets/NoEvent.png" 
        alt="No Events"
        style="
            max-width:100%;
            height:auto;
            border-radius:20px;
        ">
</div>`;
} else {
  document.getElementById('eventsList').innerHTML = DATA.events.map(ev=>`
  <div class="event-card">
    <div class="card-img-wrap">
      <img src="${ev.img}" alt="${ev.title}" loading="lazy">
      <span class="status-badge ${ev.badge}">${ev.status}</span>
    </div>
    <div class="card-info">
      <div class="card-meta-row">
        <span class="card-meta-date">${ev.date} · ${ev.time}</span>
        <span class="card-countdown">${ev.days} Days Remaining</span>
      </div>
      <div class="card-title">${ev.title}</div>
      <div class="card-desc">${ev.desc}</div>
      <div class="card-footer">
        <span class="card-location">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 1.5C5.79 1.5 4 3.29 4 5.5c0 3.5 4 9 4 9s4-5.5 4-9c0-2.21-1.79-3.5-4-3.5z" fill="currentColor" opacity=".5"/><circle cx="8" cy="5.5" r="1.5" fill="currentColor"/></svg>
          ${ev.location}
        </span>
        ${ev.reg ? '<button class="btn-register">Register</button>' : ''}
      </div>
    </div>
  </div>`).join('');
}

/* ── WHAT'S AHEAD ── */
if (DATA.whatsAhead.length === 0) {
  document.getElementById('whatsAhead').innerHTML =
    '<p style="color:var(--text-muted,#888);padding:16px">No events scheduled for today.</p>';
} else {
  document.getElementById('whatsAhead').innerHTML = DATA.whatsAhead.map(a=>`
  <div class="ahead-item">
    <div class="ahead-date-box">
      <div class="ahead-day">${a.day}</div>
      <div class="ahead-mon">${a.month}</div>
    </div>
    <div class="ahead-info">
      <div class="ahead-title">${a.title}</div>
      <div class="ahead-sub">${a.sub}</div>
    </div>
    <span class="ahead-tag">${a.tag}</span>
  </div>`).join('');
}

/* ── CAROUSEL BUILDER (responsive) ── */
function getVisibleItems() {
  const w = window.innerWidth;
  if (w < 400) return 1;
  if (w < 600) return 2;
  if (w < 900) return 3;
  return 4;
}

function buildCarousel(trackId, dotsId, itemW, gap, items, renderFn, visibleOverride) {
  const track = document.getElementById(trackId);
  const dotsEl = document.getElementById(dotsId);
  const wrapper = track.closest('.carousel-wrap');
  const panel = track.closest('.panel');

  const visible = visibleOverride !== undefined ? visibleOverride : getVisibleItems();

  track.innerHTML = items.map(renderFn).join('');

  let cur = 0;
  const max = Math.max(0, items.length - visible);

  function go(idx) {
    cur = Math.max(0, Math.min(idx, max));
    track.style.transform = `translateX(-${cur * (itemW + gap)}px)`;

    dotsEl.querySelectorAll('.c-dot').forEach((d, i) =>
      d.classList.toggle('on', i === cur)
    );
  }

  // dots
  dotsEl.innerHTML = Array.from({ length: max + 1 }, (_, i) =>
    `<div class="c-dot${i === 0 ? ' on' : ''}" data-i="${i}"></div>`
  ).join('');

  dotsEl.addEventListener('click', e => {
    const i = e.target.dataset.i;
    if (i !== undefined) go(+i);
  });

  // arrows
  const prevBtn = document.getElementById(trackId.replace('Track', 'Prev'));
  const nextBtn = document.getElementById(trackId.replace('Track', 'Next'));

  if (prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => go(cur - 1));
    nextBtn.addEventListener('click', () => go(cur + 1));
  }

  // autoplay handling
  let autoplayId = setInterval(() => go((cur + 1) % (max + 1)), 3500);

  // pause on hover over arrows or wrapper
  const pause = () => clearInterval(autoplayId);
  const resume = () => {
    clearInterval(autoplayId);
    autoplayId = setInterval(() => go((cur + 1) % (max + 1)), 3500);
  };

  if (prevBtn) {
    prevBtn.addEventListener('mouseenter', pause);
    prevBtn.addEventListener('mouseleave', resume);
  }
  if (nextBtn) {
    nextBtn.addEventListener('mouseenter', pause);
    nextBtn.addEventListener('mouseleave', resume);
  }
  if (wrapper) {
    wrapper.addEventListener('mouseenter', pause);
    wrapper.addEventListener('mouseleave', resume);
  }

  // responsive resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const newVisible = getVisibleItems();
      const newMax = Math.max(0, items.length - newVisible);
      cur = Math.min(cur, newMax);
      go(cur);
    }, 150);
  });
}


buildCarousel('bdayTrack', 'bdayDots', 126, 12, DATA.birthdays, b => `
  <div class="bday-card">
    <img class="bday-avatar" src="${b.avatar}" alt="${b.name}" loading="lazy">
    <div class="bday-name">${b.name}</div>
    <div class="bday-date-pill">🎂 ${b.date}</div>
    <div class="bday-role">${b.role}</div>
  </div>`, 2);

buildCarousel('membersTrack', 'memberDots', 96, 12, DATA.newMembers, m => `
  <div class="member-card">
    <div class="member-aw">
      <img class="member-avatar" src="${m.avatar}" alt="${m.name}" loading="lazy">
      <span class="new-pill">New</span>
    </div>
    <div class="member-name">${m.name}</div>
    <div class="member-role">${m.role}</div>
    <div class="member-joined">${m.joined}</div>
  </div>`, 2);

  buildCarousel('anniTrack', 'anniDots', 126, 12, DATA.anniversaries, a => `
  <div class="bday-card">
    <img class="bday-avatar" src="${a.avatar}" alt="${a.name}" loading="lazy">
    <div class="bday-name">${a.name}</div>
    <div class="bday-date-pill" style="background:var(--blue-bg); color:var(--blue-fg); border:1px solid var(--blue-fg)">
        ✨ ${a.years} ${a.years === 1 ? 'Year' : 'Years'}
    </div>
    <div class="bday-role">${a.date}</div>
  </div>`, 2);

// ── Hide right column entirely if all three sections have no data ──
(function () {
  const hasData =
    DATA.birthdays.length > 0 ||
    DATA.newMembers.length > 0 ||
    DATA.anniversaries.length > 0;

  if (!hasData) {
    const rightCol = document.getElementById('rightCol');
    const leftCol  = document.getElementById('leftCol');
    const grid     = document.getElementById('contentGrid');

    if (rightCol) rightCol.style.display = 'none';

    // Override the grid so left col takes full width
    if (grid) {
      grid.style.gridTemplateColumns = '1fr';
    }
    // Or if you're using flexbox instead of grid:
    // if (leftCol) leftCol.style.flex = '1 1 100%';
  }
})();

// Hide individual panels if their data is empty
if (DATA.birthdays.length  === 0) document.querySelector('#bdayTrack')  ?.closest('.panel')?.style.setProperty('display','none');
if (DATA.newMembers.length === 0) document.querySelector('#membersTrack')?.closest('.panel')?.style.setProperty('display','none');
if (DATA.anniversaries.length === 0) document.querySelector('#anniTrack')?.closest('.panel')?.style.setProperty('display','none');

</script>
