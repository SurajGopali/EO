@model List<EO.Models.Guests>

@{
    ViewData["Title"] = "Guests";
}

<link href="~/css/table.css" rel="stylesheet">

<h3 class="mb-3">Guests</h3>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-outline-success btn-sm">
        + Add Guest
    </a>
</div>

<hr />

<div class="table-container">
    <div class="table-responsive">
        <table class="custom-table align-middle">
            <thead>
                <tr>
                    <th>Avatar</th>
                    <th>Name</th>
                    <th>Designation</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model?.Any() == true)
                {
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(g.Avatar))
                                {
                                    <img src="@g.Avatar"
                                         style="width:45px;height:45px;border-radius:50%;object-fit:cover;" />
                                }
                            </td>

                            <td class="fw-bold">@g.Name</td>

                            <td class="text-muted-custom">
                                @g.Designation
                            </td>

                            <td class="text-end">
                                <div class="action-buttons">
                                    <a asp-action="Edit"
                                       asp-route-id="@g.Id"
                                       class="btn-action btn-edit"
                                       title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form asp-action="Delete"
                                          asp-route-id="@g.Id"
                                          method="post"
                                          class="d-inline">

                                        <button type="submit"
                                                class="btn-action btn-deactivate"
                                                title="Delete"
                                                onclick="return confirm('Delete this guest?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-state">
                            No guests found in the records.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>