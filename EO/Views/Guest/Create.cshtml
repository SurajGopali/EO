@model EO.Models.CreateGuestDto

@{
    ViewData["Title"] = "Create Guest";
}

<h3>Create Guest</h3>

<form asp-action="Create" method="post">

    <label>Name</label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>

    <label class="mt-2">Designation</label>
    <input asp-for="Designation" class="form-control" />

    <label class="mt-2">Avatar URL</label>
    <input asp-for="Avatar" class="form-control" />

    <button type="submit" class="btn btn-success mt-3">
        Save
    </button>

    <a asp-action="Index" class="btn btn-secondary mt-3">
        Cancel
    </a>

</form>