<div class="table-container">
    <div class="table-responsive">
        <table class="custom-table align-middle">
            <thead>
                <tr>
                    <th>Logo</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Perks</th>
                    <th>Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                         <td>
                                @if (!string.IsNullOrEmpty(item.Logo))
                                {
                                    <img src="@item.Logo"
                                         loading="lazy"
                                         style="width:45px;height:45px;object-fit:cover;border-radius:10px;" />
                                }
                            </td>
                            <td class="fw-bold">@item.Name</td>
                            <td>
                                @(item.AllianceTypeName )
                            </td>

                            <td>
                                @string.Join(", ", item.Perks.Select(p => p.Name))
                            </td>

                            <td class="text-muted-custom">
                                @item.Description
                            </td>

                            <td class="text-end">
                                <div class="action-buttons">
                                    <a class="btn-action btn-edit"
                                       href="/Alliance/Edit/@item.Id"
                                       title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a class="btn-action btn-deactivate"
                                       href="/Alliance/Delete/@item.Id"
                                       title="Delete"
                                       onclick="return confirm('Are you sure you want to delete this alliance?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="empty-state">
                            No alliances found in the records.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
