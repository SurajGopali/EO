<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EO</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
           
            .app-layout {
                display: flex;
                min-height: 100vh;
                background: #f5f5f5;
            }

           
            .sidebar {
                width: 240px;
                background: #fff;
                border-right: 1px solid #e5e5e5;
                transition: width 0.3s ease;
                overflow: hidden;
                display: flex;
                flex-direction: column;
            }

                .sidebar.collapsed {
                    width: 60px;
                }

            .sidebar-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 10px 12px;
                border-bottom: 1px solid #eee;
                background: #fff;
            }

            .sidebar-title {
                font-size: 12px;
                font-weight: 600;
                color: #888;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .toggle-btn {
                cursor: pointer;
                font-size: 18px;
                font-weight: 600;
                user-select: none;
                padding: 4px 8px;
                border-radius: 6px;
            }

                .toggle-btn:hover {
                    background: #f3f3f3;
                }

            .sidebar a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                text-decoration: none;
                color: #333;
                border-bottom: 1px solid #f1f1f1;
                white-space: nowrap;
                transition: background 0.2s;
            }

                .sidebar a:hover {
                    background: #f7f7f7;
                }

            .sidebar.collapsed .text,
            .sidebar.collapsed .sidebar-title {
                display: none;
            }

            .sidebar.collapsed a {
                justify-content: center;
                padding: 12px 0;
            }

            .main-content {
                flex: 1;
                padding: 20px;
            }

            .topbar {
                background: #fff;
                border-bottom: 1px solid #e5e5e5;
            }

            @@media (max-width: 768px) {
                .sidebar {
                    position: fixed;
                    height: 100%;
                    z-index: 1000;
                    left: 0;
                    top: 0;
                }

                    .sidebar.collapsed {
                        transform: translateX(-100%);
                        width: 240px;
                    }
            }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow topbar">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">EO</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- APP -->
    <div class="app-layout">

        @if (User.Identity.IsAuthenticated)
        {
            <aside class="sidebar" id="sidebar">

                <div class="sidebar-header">
                    <div class="sidebar-title">Menu</div>
                    <div class="toggle-btn" onclick="toggleSidebar()">☰</div>
                </div>

                <a asp-controller="Home" asp-action="Index">
                    <span class="text">Home</span>
                </a>
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a asp-controller="Profile" asp-action="Members">
                        <span class="text">Members</span>
                    </a>
                }

            </aside>
        }

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <footer class="border-top footer text-muted bg-white">
        <div class="container py-3">
            &copy; 2026 - EO - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            function toggleSidebar() {
                document.getElementById("sidebar").classList.toggle("collapsed");
            }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>