@model List<EO.Models.MemberDto>

@{
    ViewData["Title"] = "Members";
}
<link href="~/css/table.css" rel="stylesheet">


<h3 class="mb-3">Members</h3>

<div class="mb-3">
    <a class="btn btn-primary btn-sm" href="javascript:void(0);" id="addMemberBtn">
        + Add Member
    </a>

    <a class="btn btn-outline-primary btn-sm"
           asp-action="Members"
           asp-route-New="false">
        All list
    </a>

    <a class="btn btn-outline-success btn-sm"
           asp-action="Members"
           asp-route-New="true">
        New
    </a>
</div>

<hr />

<div class="table-container">
    <div class="table-responsive">
        <table class="custom-table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Roles</th>
                    <th>Company</th>
                    <th>Designation</th>
                    <th>Joined</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var m in Model)
                    {
                        <tr class="@(m.IsActive ? "" : "row-inactive")">
                            <td class="fw-bold">@m.Name</td>
                            <td><span class="badge-role">@m.EoRole</span></td>
                            <td>@m.CompanyName</td>
                            <td class="text-muted-custom">@m.Designation</td>
                            <td>@m.JoinedDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <div class="action-buttons">
                                    <a class="btn-action btn-view" href="/Profile/MemberDetails/@m.Id" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button class="btn-action btn-edit editMemberBtn" data-id="@m.Id">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <form asp-controller="Profile" asp-action="ToggleMemberStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@m.Id" />
                                        @if (m.IsActive)
                                        {
                                            <button type="submit" class="btn-action btn-deactivate" title="Deactivate">
                                                <i class="bi bi-person-x"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn-action btn-activate" title="Activate">
                                                <i class="bi bi-person-check"></i>
                                            </button>
                                        }
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            No members found in the records.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal fade" id="setupModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: max-content;">
        <div class="modal-content" id="setupModalContent" style="width: max-content; overflow: hidden; border: none; background: transparent;">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.editMemberBtn', function () {
            console.log("CLICKED");

            var id = $(this).data('id');

            $.get('/Profile/Setup/' + id, function (data) {
                console.log("DATA RECEIVED");

                $('#setupModalContent').html(data);

                var modal = new bootstrap.Modal(document.getElementById('setupModal'));
                modal.show();

                setTimeout(() => {
                    if (typeof showStep === "function") {
                        showStep(1);
                    }
                }, 200);
            });
        });
    </script>

    <script>
        $(document).ready(function () {

            $('#addMemberBtn').on('click', function () {

                $.get('/AdminUsers/CreateMemberForm', function (data) {
                    $('#setupModalContent').html(data);

                    var modal = new bootstrap.Modal(document.getElementById('setupModal'));
                    modal.show();
                });

            });

        });


        $(document).on('submit', '#registerMemberForm', function (e) {
            e.preventDefault();

            const btn = $(this).find("button[type='submit']");
            btn.text("Creating...").prop("disabled", true);

            const data = {
                FirstName: $("[name='FirstName']").val(),
                MiddleName: $("[name='MiddleName']").val(),
                LastName: $("[name='LastName']").val(),
                Email: $("[name='Email']").val(),
                MobileNumber: $("[name='MobileNumber']").val(),
                EoRole: $("[name='EoRole']").val(),
                Gender: Number($("[name='Gender']").val()),
                Password: $("[name='Password']").val(),
                ConfirmPassword: $("[name='ConfirmPassword']").val()
            };

            $.ajax({
                url: '/AdminUsers/CreateMember',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),

                success: function (res) {

                    if (res.success) {
                        Toast.success(res.message || "Member created successfully", "Success");

                        const modalEl = document.getElementById('setupModal');
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if (modal) modal.hide();

                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    }
                    else {
                        Toast.error(res.message || "Failed to create member", "Error");
                    }
                },

                error: function (err) {

                    let message = "Something went wrong!!";

                    if (err.responseJSON) {

                        if (err.responseJSON.message) {
                            message = err.responseJSON.message;
                        }

                        if (err.responseJSON.errors) {
                            message += "\n" + err.responseJSON.errors.join("\n");
                        }
                    }

                    Toast.error(message, "Try Again...");
                },

                complete: function () {
                    btn.text("Create Member").prop("disabled", false);
                }
            });
        });
    </script>



}