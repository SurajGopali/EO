@model List<EventDto>

@{
    ViewData["Title"] = "Events";
}

<link href="~/css/table.css" rel="stylesheet">

<h3 class="mb-3">Events</h3>

<div class="mb-3 d-flex align-items-center gap-2">
    <button class="btn btn-outline-success btn-sm editEventBtn" data-id="0">
        + Add Event
    </button>

    <div class="input-group input-group-sm search-wrapper">
        <span class="input-group-text pe-1">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text"
               id="eventSearch"
               class="form-control ps-2"
               placeholder="Search events..."
               oninput="filterEvents()" />
        <button class="btn btn-link text-muted"
                type="button"
                id="clearSearch"
                onclick="clearSearch()"
                style="display:none;"
                title="Clear">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <small id="searchCount" class="text-muted" style="display:none;"></small>
</div>

<hr />

<div class="table-container">
    <div class="table-responsive">
        <table class="custom-table align-middle">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Remaining</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody id="eventsTableBody">
                @if (Model?.Any() == true)
                {
                    foreach (var e in Model)
                    {
                        <tr class="event-row"
                            data-title="@e.Title?.ToLower()"
                            data-description="@e.Description?.ToLower()"
                            data-location="@e.Location?.ToLower()"
                            data-type="@e.Type?.ToLower()"
                            data-date="@e.Date.ToString("MMM dd, yyyy").ToLower()">
                            <td>
                                @if (!string.IsNullOrEmpty(e.Image))
                                {
                                    <img src="@e.Image"
                                         loading="lazy"
                                         style="width:45px;height:45px;object-fit:cover;border-radius:10px;" />
                                }
                            </td>

                            <td>
                                <div class="fw-bold">@e.Title</div>
                                <small class="text-muted-custom">@e.Description</small>
                            </td>

                            <td>@e.Date.ToString("MMM dd, yyyy")</td>

                            <td>
                                @(e.StartTime?.ToString(@"hh\:mm") ?? "-")
                                -
                                @(e.EndTime?.ToString(@"hh\:mm") ?? "-")
                            </td>

                            <td>@e.Location</td>

                            <td>
                                <span class="badge-role">@e.Type</span>
                            </td>

                            <td>
                                @if (e.IsRegistered == true)
                                {
                                    <span class="badge bg-success">Registered</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Not Registered</span>
                                }
                            </td>

                            <td>
                                @if (e.RemainingDays > 0)
                                {
                                    <span class="badge bg-warning text-dark">
                                        @e.RemainingDays days
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Started
                                    </span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="action-buttons">
                                    <a class="btn-action btn-view"
                                           asp-controller="Event"
                                           asp-action="Details"
                                           asp-route-id="@e.Id"
                                           title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <button class="btn-action btn-edit editEventBtn" data-id="@e.Id" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button type="button"
                                            class="btn-action btn-deactivate deleteEventBtn"
                                            data-id="@e.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="empty-state">
                            No events found in the records.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="noResults" class="empty-state text-center py-4" style="display:none;">
            No events match your search.
        </div>
    </div>
</div>

<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width: max-content;">
        <div class="modal-content" id="eventModalContent" style="width: max-content; overflow: hidden; border: none; background: transparent;">
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).on('click', '.editEventBtn', function () {

            console.log("CLICKED"); 

            var id = $(this).data('id');

            $.get('/Event/Edit', { id: id }, function (data) {

                console.log("DATA RECEIVED");

                $('#eventModalContent').html(data);

                var modal = new bootstrap.Modal(document.getElementById('eventModal'));
                modal.show();

            }).fail(function (err) {
                console.error("ERROR:", err);
            });

        });

             function filterEvents() {
            const query = document.getElementById('eventSearch').value.trim().toLowerCase();
            const rows = document.querySelectorAll('.event-row');
            const clearBtn = document.getElementById('clearSearch');
            const countEl = document.getElementById('searchCount');
            const noResults = document.getElementById('noResults');

            clearBtn.style.display = query ? 'block' : 'none';

            let visibleCount = 0;

            rows.forEach(row => {
                const searchable = [
                    row.dataset.title,
                    row.dataset.description,
                    row.dataset.location,
                    row.dataset.type,
                    row.dataset.date
                ].join(' ');

                const match = !query || searchable.includes(query);
                row.style.display = match ? '' : 'none';
                if (match) visibleCount++;
            });

            const hasRows = rows.length > 0;

            if (query && hasRows) {
                countEl.style.display = 'inline';
                countEl.textContent = `${visibleCount} of ${rows.length} shown`;
            } else {
                countEl.style.display = 'none';
            }

            noResults.style.display = (query && visibleCount === 0) ? 'block' : 'none';
        }

        function clearSearch() {
            document.getElementById('eventSearch').value = '';
            filterEvents();
            document.getElementById('eventSearch').focus();
        }

                $(document).on('click', '.deleteEventBtn', function () {

            var button = $(this);
            var id = button.data('id');

            if (!confirm('Are you sure you want to delete this event?')) return;

            $.ajax({
                url: '/Event/Delete',
                type: 'POST',
                data: {
                    id: id,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (res) {

                    if (res.success) {

                        showToast(res.message, "success");

                        button.closest('tr').fadeOut(300, function () {
                            $(this).remove();
                        });

                    } else {
                        showToast("Something went wrong", "error");
                    }

                },
                error: function () {
                    showToast("Server error occurred", "error");
                }
            });

        });
    </script>
}