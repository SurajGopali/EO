@model EventIndexViewModel

@{
    ViewData["Title"] = "Events";
}

<link href="~/css/table.css" rel="stylesheet">

<h3 class="mb-3">Events</h3>

<div class="mb-3 d-flex align-items-center gap-2">

    <button class="btn btn-outline-success btn-sm editEventBtn" data-id="0">
        + Add Event
    </button>

    <div class="input-group input-group-sm search-wrapper">
        <span class="input-group-text">
            <i class="bi bi-search"></i>
        </span>

        <input type="text"
               id="eventSearch"
               class="form-control"
               placeholder="Search events..."
               oninput="filterEvents()" />

        <button class="btn btn-link"
                type="button"
                onclick="clearSearch()"
                id="clearSearch"
                style="display:none;">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

</div>

<hr />

<div class="table-container">
    <div class="table-responsive">

        <table class="custom-table align-middle">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th>Remaining</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model?.Events?.Any() == true)
                {
                    foreach (var e in Model.Events)
                    {
                        <tr class="event-row"
                            data-title="@e.Title?.ToLower()"
                            data-location="@e.Location?.ToLower()"
                            data-type="@e.Type?.ToLower()"
                            data-date="@e.Date.ToString("MMM dd yyyy").ToLower()">

                            <td>
                                @if (!string.IsNullOrEmpty(e.Image))
                                {
                                    <img src="@e.Image" style="width:45px;height:45px;border-radius:8px;object-fit:cover;" />
                                }
                            </td>

                            <td>
                                <b>@e.Title</b><br />
                                <small>@e.Description</small>
                            </td>

                            <td>@e.Date.ToString("MMM dd, yyyy")</td>

                            <td>
                                @(e.StartTime?.ToString(@"hh\:mm") ?? "-")
                                -
                                @(e.EndTime?.ToString(@"hh\:mm") ?? "-")
                            </td>

                            <td>@e.Location</td>

                            <td><span class="badge bg-secondary">@e.Type</span></td>

                            <td>
                                @if (e.RemainingDays > 0)
                                {
                                    <span class="badge bg-warning">@e.RemainingDays days</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Started</span>
                                }
                            </td>

                            <td class="text-end">

                                <button class="btn btn-sm btn-primary registerBtn"
                                        data-id="@e.Id">
                                    Register
                                </button>

                                <!-- VIEW -->
                                <a class="btn-action btn-view"
                                       asp-controller="Event"
                                       asp-action="Details"
                                       asp-route-id="@e.Id"
                                       title="View">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <!-- EDIT -->
                                <button class="btn-action btn-edit editEventBtn"
                                        data-id="@e.Id"
                                        title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                <!-- DELETE -->
                                <button type="button"
                                        class="btn-action btn-deactivate deleteEventBtn"
                                        data-id="@e.Id"
                                        title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            No events found
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<!-- EVENT MODAL -->
<div class="modal fade" id="eventModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" id="eventModalContent"></div>
    </div>
</div>

<!-- RSVP MODAL -->
<div class="modal fade" id="rsvpModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-3">

            <h5>Select Response</h5>

            <div id="rsvpOptions">
                <div class="text-muted text-center">Loading...</div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>

        let currentEventId = 0;

        /* ---------------- EDIT EVENT ---------------- */
        $(document).on('click', '.editEventBtn', function () {

            const id = parseInt($(this).attr('data-id'));

            $.get('/Event/Edit', { id: id }, function (html) {
                $('#eventModalContent').html(html);
                new bootstrap.Modal(document.getElementById('eventModal')).show();
            });

        });

        /* ---------------- REGISTER CLICK ---------------- */
                $(document).on('click', '.registerBtn', function () {

            const eventId = parseInt($(this).attr('data-id'));

            if (!eventId || eventId <= 0) {
                Toast.error("Invalid event selected");
                return;
            }

            // store inside modal (NO GLOBAL VARIABLE)
            $('#rsvpModal').data('event-id', eventId);

            $('#rsvpOptions').html('<div class="text-muted text-center">Loading...</div>');

            $.get('/Event/GetResponseTypes', function (data) {

                let html = '';

                data.forEach(r => {
                    html += `
                        <button class="btn btn-outline-primary w-100 mb-2 rsvp-option"
                                data-response-id="${r.id}">
                            ${r.name}
                        </button>`;
                });

                $('#rsvpOptions').html(html);
            });

            new bootstrap.Modal(document.getElementById('rsvpModal')).show();
        });

        /* ---------------- RSVP SUBMIT ---------------- */
                 $(document).on('click', '.rsvp-option', function () {

            const eventId = parseInt($('#rsvpModal').data('event-id'));
            const responseTypeId = parseInt($(this).data('response-id'));

            console.log("EVENT ID:", eventId);
            console.log("RESPONSE ID:", responseTypeId);

            if (!eventId || !responseTypeId) {
                Toast.error("Invalid selection");
                return;
            }

            $.ajax({
                url: '/Event/Register',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    eventId: eventId,
                    responseTypeId: responseTypeId
                }),
                success: function (res) {
                    if (res.success) {
                        Toast.success("Response saved");
                        bootstrap.Modal.getInstance(document.getElementById('rsvpModal')).hide();
                    }
                },
                error: function () {
                    Toast.error("Something went wrong");
                }
            });
        });

        /* ---------------- SEARCH ---------------- */
        function filterEvents() {

            const query = $('#eventSearch').val().toLowerCase();
            const rows = $('.event-row');

            let visible = 0;

            rows.each(function () {

                const row = $(this);
                const text = (
                    row.data('title') + " " +
                    row.data('location') + " " +
                    row.data('type') + " " +
                    row.data('date')
                );

                const match = !query || text.includes(query);

                row.toggle(match);

                if (match) visible++;
            });

        }

        /* ---------------- CLEAR ---------------- */
        function clearSearch() {
            $('#eventSearch').val('');
            filterEvents();
        }

                $(document).on('click', '.deleteEventBtn', function () {

            var button = $(this);
            var id = button.attr('data-id');


            /* ------------- DELETE --------------*/

            showDeleteModal({
                message: "Are you sure you want to delete this event?"
            }).then((confirmed) => {

                if (!confirmed) return;

                $.ajax({
                    url: '/Event/Delete',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {

                        if (res.success) {

                            Toast.success(res.message, "success");

                            button.closest('tr').fadeOut(300, function () {
                                $(this).remove();
                            });

                        } else {
                            Toast.error("Something went wrong");
                        }

                    },
                    error: function () {
                        Toast.error("Server error occurred");
                    }
                });

            });

        });

    </script>
}