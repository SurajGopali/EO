@model EO.Models.UpdateProfileRequest

<link rel="stylesheet" href="~/css/memberSetup.css" asp-append-version="true" />


<div class="mf-page">
<div class="mf-card">

    <div class="mf-heading">Profile Setup</div>
    <div class="mf-subtitle">Complete each section to build your profile</div>

    <!-- â”€â”€ Stepper â”€â”€ -->
    <div class="mf-stepper">
        <div class="mf-stepper-line"></div>
        <div class="mf-step-item">
            <div class="mf-step-circle active" id="mf-sc-1">1</div>
            <div class="mf-step-label active" id="mf-sl-1">Personal</div>
        </div>
        <div class="mf-step-item">
            <div class="mf-step-circle pending" id="mf-sc-2">2</div>
            <div class="mf-step-label" id="mf-sl-2">Company</div>
        </div>
        <div class="mf-step-item">
            <div class="mf-step-circle pending" id="mf-sc-3">3</div>
            <div class="mf-step-label" id="mf-sl-3">Social</div>
        </div>
        <div class="mf-step-item">
            <div class="mf-step-circle pending" id="mf-sc-4">4</div>
            <div class="mf-step-label" id="mf-sl-4">Spouse</div>
        </div>
        <div class="mf-step-item">
            <div class="mf-step-circle pending" id="mf-sc-5">5</div>
            <div class="mf-step-label" id="mf-sl-5">Children</div>
        </div>
        <div class="mf-step-item">
            <div class="mf-step-circle pending" id="mf-sc-6">6</div>
            <div class="mf-step-label" id="mf-sl-6">Review</div>
        </div>
    </div>

    <!-- â”€â”€ Progress bar â”€â”€ -->
    <div class="mf-progress-track">
        <div class="mf-progress-fill" id="progress" style="width:0%;"></div>
    </div>

    <!-- â”€â”€ Section header â”€â”€ -->
    <div class="mf-section-row">
        <div class="mf-section-title" id="mf-section-title">Personal Details:</div>
        <div class="mf-section-count" id="mf-section-count">Step 1 of 6</div>
    </div>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         YOUR ORIGINAL FORM â€” tags untouched
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    <form id="profileForm">

        <!-- STEP 1 -->
        <div class="step active" data-step="1">
            <h3>Personal Details</h3>

            <label>Date of Birth</label>
            <input name="PersonalDetails.DateOfBirth"
                   type="date"
                   value="@Model?.PersonalDetails?.DateOfBirth?.ToString("yyyy-MM-dd")" />

            <label>Address</label>
            <input name="PersonalDetails.Address"
                   value="@Model?.PersonalDetails?.Address" />

            <label>Bio</label>
            <textarea name="PersonalDetails.Bio">@Model?.PersonalDetails?.Bio</textarea>

            <div class="mf-checkbox-row">
                <input type="checkbox"
                       id="isMarried"
                       name="PersonalDetails.IsMarried"
                       @(Model?.PersonalDetails?.IsMarried == true ? "checked" : "") />
                <label for="isMarried">Married</label>
            </div>

            <label>Anniversary Date</label>
            <input id="anniversaryField"
                   name="PersonalDetails.AnniversaryDate"
                   type="date"
                   value="@Model?.PersonalDetails?.AnniversaryDate?.ToString("yyyy-MM-dd")" />
        </div>

        <!-- STEP 2 -->
        <div class="step" data-step="2">
            <h3>Company Details</h3>

            <label>Company Name</label>
            <input name="CompanyDetails.CompanyName"
                   value="@Model?.CompanyDetails?.CompanyName" />

            <label>Designation</label>
            <input name="CompanyDetails.Designation"
                   value="@Model?.CompanyDetails?.Designation" />

            <label>Role</label>
            <input name="CompanyDetails.Role"
                   value="@Model?.CompanyDetails?.Role" />
        </div>

        <!-- STEP 3 -->
        <div class="step" data-step="3">
            <h3>Social Links</h3>

            <label>Facebook</label>
            <input name="SocialLinks.Facebook" value="@Model?.SocialLinks?.Facebook" />

            <label>Instagram</label>
            <input name="SocialLinks.Instagram" value="@Model?.SocialLinks?.Instagram" />

            <label>LinkedIn</label>
            <input name="SocialLinks.LinkedIn" value="@Model?.SocialLinks?.LinkedIn" />

            <label>X</label>
            <input name="SocialLinks.X" value="@Model?.SocialLinks?.X" />

            <label>Website</label>
            <input name="SocialLinks.Website" value="@Model?.SocialLinks?.Website" />
        </div>

        <!-- STEP 4 â€” SPOUSE -->
        <div class="step" data-step="4">
            <h3>Spouse Details</h3>

            <label>Name</label>
            <input name="Spouse.Name" value="@Model?.Spouse?.Name" />

            <label>Phone</label>
            <input name="Spouse.Phone" value="@Model?.Spouse?.Phone" />

            <label>Email</label>
            <input name="Spouse.Email" value="@Model?.Spouse?.Email" />

            <label>Date of Birth</label>
            <input name="Spouse.DateOfBirth"
                   type="date"
                   value="@Model?.Spouse?.DateOfBirth?.ToString("yyyy-MM-dd")" />

            <label>Profile Image</label>
            <input name="Spouse.ProfileImage"
                   value="@Model?.Spouse?.ProfileImage" />

            <hr />

            <h4>Spouse Social Links</h4>

            <label>Facebook</label>
            <input name="Spouse.SocialLinks.Facebook"
                   value="@Model?.Spouse?.SocialLinks?.Facebook" />

            <label>Instagram</label>
            <input name="Spouse.SocialLinks.Instagram"
                   value="@Model?.Spouse?.SocialLinks?.Instagram" />

            <label>LinkedIn</label>
            <input name="Spouse.SocialLinks.LinkedIn"
                   value="@Model?.Spouse?.SocialLinks?.LinkedIn" />

            <label>X</label>
            <input name="Spouse.SocialLinks.X"
                   value="@Model?.Spouse?.SocialLinks?.X" />

            <label>Website</label>
            <input name="Spouse.SocialLinks.Website"
                   value="@Model?.Spouse?.SocialLinks?.Website" />

            <hr />

            <h4>Spouse Professional</h4>

            <label>Current Company</label>
            <input name="Spouse.Professional.CurrentCompany"
                   value="@Model?.Spouse?.Professional?.CurrentCompany" />

            <label>Position</label>
            <input name="Spouse.Professional.Position"
                   value="@Model?.Spouse?.Professional?.Position" />

            <label>Experience Years</label>
            <input name="Spouse.Professional.ExperienceYears"
                   value="@Model?.Spouse?.Professional?.ExperienceYears" />

            <label>Previous Roles</label>
            <div id="previousRolesContainer">
                @if (Model?.Spouse?.Professional?.PreviousRoles != null && Model.Spouse.Professional.PreviousRoles.Any())
                {
                    foreach (var role in Model.Spouse.Professional.PreviousRoles)
                    {
                        <div class="tag-item">
                            <input name="Spouse.Professional.PreviousRoles" value="@role" />
                            <button type="button" onclick="removeTag(this)">x</button>
                        </div>
                    }
                }
                else
                {
                    <div class="tag-item">
                        <input name="Spouse.Professional.PreviousRoles" />
                        <button type="button" onclick="removeTag(this)">x</button>
                    </div>
                }
            </div>
            <button type="button" class="mf-add-btn" onclick="addPreviousRole()">+ Add Role</button>

            <label>Expertise</label>
            <div id="expertiseContainer">
                @if (Model?.Spouse?.Professional?.Expertise != null && Model.Spouse.Professional.Expertise.Any())
                {
                    foreach (var exp in Model.Spouse.Professional.Expertise)
                    {
                        <div class="tag-item">
                            <input name="Spouse.Professional.Expertise" value="@exp" />
                            <button type="button" onclick="removeTag(this)">x</button>
                        </div>
                    }
                }
                else
                {
                    <div class="tag-item">
                        <input name="Spouse.Professional.Expertise" />
                        <button type="button" onclick="removeTag(this)">x</button>
                    </div>
                }
            </div>
            <button type="button" class="mf-add-btn" onclick="addExpertise()">+ Add Expertise</button>
        </div>

        <!-- STEP 5 - CHILDREN -->
        <div class="step" data-step="5">
            <h3>Children</h3>

            <div id="childrenContainer">
                @if (Model?.Children != null && Model.Children.Any())
                {
                    for (int i = 0; i < Model.Children.Count; i++)
                    {
                        <div class="child-item">
                            <input type="hidden" name="Children[@i].Id" value="@Model.Children[i].Id" />

                            <label>Name</label>
                            <input name="Children[@i].Name" value="@Model.Children[i].Name" />

                            <label>School</label>
                            <input name="Children[@i].School" value="@Model.Children[i].School" />

                            <label>Grade</label>
                            <input name="Children[@i].Grade" value="@Model.Children[i].Grade" />

                            <label>Date of Birth</label>
                            <input type="date"
                                   name="Children[@i].DateOfBirth"
                                   value="@Model.Children[i].DateOfBirth?.ToString("yyyy-MM-dd")" />

                            <label>Profile Image</label>
                            <input name="Children[@i].ProfileImage"
                                   value="@Model.Children[i].ProfileImage" />

                            <button type="button" onclick="removeChildItem(this)">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <div class="child-item">
                        <input type="hidden" name="Children[0].Id" value="" />

                        <label>Name</label>
                        <input name="Children[0].Name" />

                        <label>School</label>
                        <input name="Children[0].School" />

                        <label>Grade</label>
                        <input name="Children[0].Grade" />

                        <label>Date of Birth</label>
                        <input type="date" name="Children[0].DateOfBirth" />

                        <label>Profile Image</label>
                        <input name="Children[0].ProfileImage" />

                        <button type="button" onclick="removeChildItem(this)">Remove</button>
                    </div>
                }
            </div>

            <button type="button" class="mf-add-btn" onclick="addChild()">+ Add Child</button>
        </div>

        <!-- STEP 6 â€” REVIEW -->
        <div class="step" data-step="6">
            <h3>Review Your Profile</h3>
            <div id="reviewContainer" class="review-grid"></div>
        </div>

        <!-- â”€â”€ Navigation (replaces original btn-group) â”€â”€ -->
        <div class="btn-group"></div><!-- kept so Razor doesn't error; hidden via CSS -->

    </form>

    <!-- nav lives outside <form> so it doesn't accidentally submit -->
    <div class="mf-btn-row">
        <button class="mf-btn-back" id="mf-btn-back" onclick="prevStep()" style="display:none;">&#8592; Back</button>
        <button class="mf-btn-next" id="nextBtn" onclick="nextStep()">Next &#8594;</button>
        <button class="mf-btn-submit" id="submitBtn" onclick="submitForm()" style="display:none;">Submit</button>
    </div>

</div><!-- /.mf-card -->
</div><!-- /.mf-page -->

<script src="~/js/profile-wizard.js"></script>

<script>
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  YOUR WORKING SCRIPT â€” unchanged logic.
    //  Shell bridge: updateShell() is called after every step change
    //  to keep the styled stepper + section header in sync.
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    let step = 1;
    let childIndex = 0;
    const totalSteps = 6;

    const STEP = {
        PERSONAL:  1,
        COMPANY:   2,
        SOCIAL:    3,
        SPOUSE:    4,
        CHILDREN:  5,
        REVIEW:    6
    };

    // â”€â”€ Shell config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    const MF_TITLES = [
        'Personal Details:',
        'Company Details:',
        'Social Links:',
        'Spouse Details:',
        'Children:',
        'Review & Submit:'
    ];
    const MF_TOTAL = 6;

    // Called after every step change to sync the visual shell
    function updateShell(currentStep) {
        // section header
        document.getElementById('mf-section-title').textContent = MF_TITLES[currentStep - 1];
        document.getElementById('mf-section-count').textContent = 'Step ' + currentStep + ' of ' + MF_TOTAL;

        // back button (outside form, id="mf-btn-back")
        document.getElementById('mf-btn-back').style.display = currentStep > 1 ? 'block' : 'none';

        // stepper circles
        for (let i = 1; i <= MF_TOTAL; i++) {
            const circle = document.getElementById('mf-sc-' + i);
            const label  = document.getElementById('mf-sl-' + i);
            if (!circle || !label) continue;
            circle.className = 'mf-step-circle ' + (i === currentStep ? 'active' : i < currentStep ? 'done' : 'pending');
            label.className  = 'mf-step-label'   + (i === currentStep ? ' active' : i < currentStep ? ' done' : '');
        }

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    document.addEventListener("DOMContentLoaded", () => {
        toggleAnniversary();
        showStep(step);
        childIndex = document.querySelectorAll(".child-item").length || 0;
    });

    // ---------------- STEP CONTROL ----------------

    function isMarried() {
        return document.getElementById("isMarried").checked;
    }

    function getNextStep(current) {
        const married = isMarried();
        if (!married) {
            if (current === STEP.SOCIAL)  return STEP.REVIEW;
            if (current === STEP.REVIEW)  return STEP.REVIEW;
        }
        return current + 1;
    }

    function getPrevStep(current) {
        const married = isMarried();
        if (!married) {
            if (current === STEP.REVIEW)   return STEP.SOCIAL;
            if (current === STEP.CHILDREN) return STEP.SOCIAL;
        }
        return current - 1;
    }

    function showStep(s) {
        const married = isMarried();

        if (!married && s === STEP.SPOUSE) {
            step = STEP.SOCIAL;
            return showStep(step);
        }
        if (!married && s === STEP.CHILDREN) {
            step = STEP.REVIEW;
            return showStep(step);
        }

        document.querySelectorAll(".step").forEach(x => x.classList.remove("active"));
        const active = document.querySelector(`[data-step="${s}"]`);
        if (active) active.classList.add("active");

        if (s === STEP.REVIEW) buildReview();

        // your original nav buttons (inside .btn-group, hidden by CSS â€” submitBtn/nextBtn still in DOM via the shell)
        document.getElementById("submitBtn").style.display = (s === STEP.REVIEW) ? "inline-block" : "none";
        document.getElementById("nextBtn").style.display   = (s === STEP.REVIEW) ? "none" : "inline-block";

        updateProgress();
        updateShell(s);  // â† sync visual shell
    }

    function nextStep() {
        step = getNextStep(step);
        if (step > totalSteps) step = totalSteps;
        showStep(step);
    }

    function prevStep() {
        step = getPrevStep(step);
        if (step < 1) step = 1;
        showStep(step);
    }

    function updateProgress() {
        const progress = ((step - 1) / (totalSteps - 1)) * 100;
        document.getElementById("progress").style.width = progress + "%";
    }

    // ---------------- MARRIED ----------------

    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("isMarried").addEventListener("change", () => {
            toggleAnniversary();
            showStep(step);
        });
    });

    function toggleAnniversary() {
        const field = document.getElementById("anniversaryField");
        const label = field.previousElementSibling;

        if (isMarried()) {
            label.style.display = "block";
            field.style.display = "block";
        } else {
            label.style.display = "none";
            field.style.display = "none";
            field.value = "";
        }
    }

    // ---------------- CHILDREN ----------------

    function addChild() {
        const container = document.getElementById("childrenContainer");
        const index = Date.now();

        container.insertAdjacentHTML("beforeend", `
            <div class="child-item">
                <input type="hidden" name="Children[${index}].Id" value="" />

                <label>Name</label>
                <input name="Children[${index}].Name" />

                <label>School</label>
                <input name="Children[${index}].School" />

                <label>Grade</label>
                <input name="Children[${index}].Grade" />

                <label>Date of Birth</label>
                <input type="date" name="Children[${index}].DateOfBirth" />

                <label>Profile Image</label>
                <input name="Children[${index}].ProfileImage" />

                <button type="button" onclick="removeChildItem(this)">Remove</button>
            </div>
        `);
    }

    function removeChildItem(btn) {
        const row = btn.closest(".child-item");
        if (row) row.remove();
    }

    function getChildren() {
        if (!isMarried()) return [];

        const rows = document.querySelectorAll(".child-item");
        let list = [];

        rows.forEach(row => {
            const id     = row.querySelector('[name*=".Id"]')?.value?.trim();
            const name   = row.querySelector('[name*=".Name"]')?.value?.trim();
            const school = row.querySelector('[name*=".School"]')?.value?.trim();
            const grade  = row.querySelector('[name*=".Grade"]')?.value?.trim();
            const dob    = row.querySelector('[name*=".DateOfBirth"]')?.value;
            const image  = row.querySelector('[name*=".ProfileImage"]')?.value?.trim();

            const isEmpty = !name && !school && !grade && !dob && !image;
            if (isEmpty) return;

            list.push({
                id: id ? parseInt(id) : null,
                name: name || null,
                school: school || null,
                grade: grade || null,
                dateOfBirth: dob || null,
                profileImage: image || null
            });
        });

        return list;
    }

    // ---------------- TAG SYSTEM ----------------

    function addPreviousRole() {
        const container = document.getElementById("previousRolesContainer");
        container.insertAdjacentHTML("beforeend", `
            <div class="tag-item">
                <input name="Spouse.Professional.PreviousRoles" />
                <button type="button" onclick="removeTag(this)">x</button>
            </div>
        `);
    }

    function addExpertise() {
        const container = document.getElementById("expertiseContainer");
        container.insertAdjacentHTML("beforeend", `
            <div class="tag-item">
                <input name="Spouse.Professional.Expertise" />
                <button type="button" onclick="removeTag(this)">x</button>
            </div>
        `);
    }

    function removeTag(btn) {
        const item = btn.closest(".tag-item");
        if (item) item.remove();
    }

    // ---------------- HELPERS ----------------

    function getValue(name) {
        const el = document.querySelector(`[name="${name}"]`);
        return el ? el.value || null : null;
    }

    function getList(name) {
        return Array.from(document.querySelectorAll(`[name="${name}"]`))
            .map(x => x.value?.trim())
            .filter(x => x && x.length > 0);
    }

    // ---------------- CHILDREN REVIEW ----------------

    function renderChildrenReview() {
        const rows = document.querySelectorAll(".child-item");

        if (!rows.length) {
            return `
                <div class="review-row">
                    <div class="review-label">Children</div>
                    <div class="review-value">No children added</div>
                </div>
            `;
        }

        let html = "";

        rows.forEach((row, index) => {
            const name   = row.querySelector('[name*=".Name"]')?.value;
            const school = row.querySelector('[name*=".School"]')?.value;
            const grade  = row.querySelector('[name*=".Grade"]')?.value;
            const dob    = row.querySelector('[name*=".DateOfBirth"]')?.value;
            const image  = row.querySelector('[name*=".ProfileImage"]')?.value;

            if (!name && !school && !grade && !dob && !image) return;

            html += `
                <div style="border:1px solid #e0ddf5;padding:12px;margin-bottom:12px;background:#f7f7fb;">
                    <div style="font-weight:600;margin-bottom:8px;color:#6C5CE7;">Child ${index + 1}</div>
                    <div class="review-row"><div class="review-label">Name</div><div class="review-value">${name || "-"}</div></div>
                    <div class="review-row"><div class="review-label">School</div><div class="review-value">${school || "-"}</div></div>
                    <div class="review-row"><div class="review-label">Grade</div><div class="review-value">${grade || "-"}</div></div>
                    <div class="review-row"><div class="review-label">Date of Birth</div><div class="review-value">${dob || "-"}</div></div>
                    <div class="review-row"><div class="review-label">Profile Image</div><div class="review-value">${image ? `<a href="${image}" target="_blank">View</a>` : "-"}</div></div>
                </div>
            `;
        });

        return html;
    }

    // ---------------- REVIEW ----------------

    function buildReview() {
        const married = isMarried();

        const html = `
            <div class="review-card">
                <div class="review-title"><span class="section-badge">Personal</span> Personal Details</div>
                <div class="review-row"><div class="review-label">Date of Birth</div><div class="review-value">${getValue("PersonalDetails.DateOfBirth") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Address</div><div class="review-value">${getValue("PersonalDetails.Address") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Bio</div><div class="review-value">${getValue("PersonalDetails.Bio") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Married</div><div class="review-value">${married ? "Yes" : "No"}</div></div>
                <div class="review-row"><div class="review-label">Anniversary</div><div class="review-value">${getValue("PersonalDetails.AnniversaryDate") || "-"}</div></div>
            </div>

            <div class="review-card">
                <div class="review-title"><span class="section-badge">Work</span> Company Details</div>
                <div class="review-row"><div class="review-label">Company</div><div class="review-value">${getValue("CompanyDetails.CompanyName") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Designation</div><div class="review-value">${getValue("CompanyDetails.Designation") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Role</div><div class="review-value">${getValue("CompanyDetails.Role") || "-"}</div></div>
            </div>

            <div class="review-card">
                <div class="review-title"><span class="section-badge">Social</span> Social Links</div>
                <div class="review-row"><div class="review-label">Facebook</div><div class="review-value">${getValue("SocialLinks.Facebook") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Instagram</div><div class="review-value">${getValue("SocialLinks.Instagram") || "-"}</div></div>
                <div class="review-row"><div class="review-label">LinkedIn</div><div class="review-value">${getValue("SocialLinks.LinkedIn") || "-"}</div></div>
                <div class="review-row"><div class="review-label">X</div><div class="review-value">${getValue("SocialLinks.X") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Website</div><div class="review-value">${getValue("SocialLinks.Website") || "-"}</div></div>
            </div>

            ${married ? `
            <div class="review-card">
                <div class="review-title"><span class="section-badge">Family</span> Spouse Profile</div>

                <h4 style="margin-top:10px;">Basic Details</h4>
                <div class="review-row"><div class="review-label">Name</div><div class="review-value">${getValue("Spouse.Name") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Phone</div><div class="review-value">${getValue("Spouse.Phone") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Email</div><div class="review-value">${getValue("Spouse.Email") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Date of Birth</div><div class="review-value">${getValue("Spouse.DateOfBirth") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Profile Image</div><div class="review-value">${getValue("Spouse.ProfileImage") ? `<a href="${getValue("Spouse.ProfileImage")}" target="_blank">View</a>` : "-"}</div></div>

                <hr />
                <h4>Social Links</h4>
                <div class="review-row"><div class="review-label">Facebook</div><div class="review-value">${getValue("Spouse.SocialLinks.Facebook") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Instagram</div><div class="review-value">${getValue("Spouse.SocialLinks.Instagram") || "-"}</div></div>
                <div class="review-row"><div class="review-label">LinkedIn</div><div class="review-value">${getValue("Spouse.SocialLinks.LinkedIn") || "-"}</div></div>
                <div class="review-row"><div class="review-label">X</div><div class="review-value">${getValue("Spouse.SocialLinks.X") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Website</div><div class="review-value">${getValue("Spouse.SocialLinks.Website") || "-"}</div></div>

                <hr />
                <h4>Professional Details</h4>
                <div class="review-row"><div class="review-label">Company</div><div class="review-value">${getValue("Spouse.Professional.CurrentCompany") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Position</div><div class="review-value">${getValue("Spouse.Professional.Position") || "-"}</div></div>
                <div class="review-row"><div class="review-label">Experience</div><div class="review-value">${getValue("Spouse.Professional.ExperienceYears") || "-"} years</div></div>
                <div class="review-row">
                    <div class="review-label">Previous Roles</div>
                    <div class="review-value"><ul class="review-list">${getList("Spouse.Professional.PreviousRoles").map(x => `<li>${x}</li>`).join("")}</ul></div>
                </div>
                <div class="review-row">
                    <div class="review-label">Expertise</div>
                    <div class="review-value"><ul class="review-list">${getList("Spouse.Professional.Expertise").map(x => `<li>${x}</li>`).join("")}</ul></div>
                </div>
            </div>
            ` : ""}

            <div class="review-card">
                <div class="review-title"><span class="section-badge">Kids</span> Children</div>
                ${renderChildrenReview()}
            </div>
        `;

        document.getElementById("reviewContainer").innerHTML = html;
    }

    // ---------------- SUBMIT ----------------

    async function submitForm() {
        const married = isMarried();

        const obj = {
            userId: "@Model.UserId",

            personalDetails: {
                dateOfBirth:     getValue("PersonalDetails.DateOfBirth"),
                anniversaryDate: getValue("PersonalDetails.AnniversaryDate"),
                address:         getValue("PersonalDetails.Address"),
                bio:             getValue("PersonalDetails.Bio"),
                isMarried:       married
            },

            companyDetails: {
                companyName:  getValue("CompanyDetails.CompanyName"),
                designation:  getValue("CompanyDetails.Designation"),
                role:         getValue("CompanyDetails.Role")
            },

            socialLinks: {
                facebook:  getValue("SocialLinks.Facebook"),
                instagram: getValue("SocialLinks.Instagram"),
                linkedIn:  getValue("SocialLinks.LinkedIn"),
                x:         getValue("SocialLinks.X"),
                website:   getValue("SocialLinks.Website")
            },

            spouse: married ? {
                name:         getValue("Spouse.Name"),
                phone:        getValue("Spouse.Phone"),
                email:        getValue("Spouse.Email"),
                dateOfBirth:  getValue("Spouse.DateOfBirth"),
                profileImage: getValue("Spouse.ProfileImage"),

                socialLinks: {
                    facebook:  getValue("Spouse.SocialLinks.Facebook"),
                    instagram: getValue("Spouse.SocialLinks.Instagram"),
                    linkedIn:  getValue("Spouse.SocialLinks.LinkedIn"),
                    x:         getValue("Spouse.SocialLinks.X"),
                    website:   getValue("Spouse.SocialLinks.Website")
                },

                professional: {
                    currentCompany:  getValue("Spouse.Professional.CurrentCompany"),
                    position:        getValue("Spouse.Professional.Position"),
                    experienceYears: getValue("Spouse.Professional.ExperienceYears"),
                    previousRoles:   getList("Spouse.Professional.PreviousRoles"),
                    expertise:       getList("Spouse.Professional.Expertise")
                }
            } : null,

            children: getChildren()
        };

        const res = await fetch("/Profile/Submit", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(obj)
        });

        if (res.ok) {
            window.location.href = "/";
        } else {
            alert("Failed");
        }
    }
</script>


