@model EO.Models.UpdateEventDetailFullDto

@{
    ViewData["Title"] = "Edit Event";

    var start = Model.Event.StartDateTime == default
        ? DateTime.Now
        : Model.Event.StartDateTime;

    var end = Model.Event.EndDateTime == default
        ? DateTime.Now
        : Model.Event.EndDateTime;

    var scheduleCount = Model.Schedule?.Count ?? 0;
    Layout = null;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<style>
    [data-theme="dark"] input[type="datetime-local"]::-webkit-calendar-picker-indicator,
    [data-theme="dark"] input[type="date"]::-webkit-calendar-picker-indicator,
    [data-theme="dark"] input[type="time"]::-webkit-calendar-picker-indicator {
        filter: invert(1);
    }
</style>

<div class="mf-page">
    <div class="mf-card">

        <div class="mf-heading">Update Event</div>
        <div class="mf-subtitle">Manage event, schedule and guests</div>

        <form id="editDetailsForm"
              enctype="multipart/form-data">

            <input type="hidden" name="EventId" value="@Model.EventId" />

            <h4>Event Details</h4>

            <label>Title</label>
            <input asp-for="Event.Title" />

            <label>Description</label>
            <textarea asp-for="Event.Description"></textarea>

            <label>Venue</label>
            <input asp-for="Event.Venue" />

            <label>Cover Image</label>

            <input type="file"
                   name="Event.CoverImageFile"
                   onchange="previewCover(event)" />

            @if (!string.IsNullOrEmpty(Model.Event.CoverImage))
            {
                <div style="margin-top:10px;">
                    <img id="coverPreview"
                         src="@Model.Event.CoverImage"
                         width="150"
                         style="border-radius:8px;" />
                </div>
            }
            else
            {
                <img id="coverPreview"
                     style="display:none; width:150px; border-radius:8px;" />
            }

            <label>Start DateTime</label>
            <input type="datetime-local"
                   name="Event.StartDateTime"
                   value="@start.ToString("yyyy-MM-ddTHH:mm")" />

            <label>End DateTime</label>
            <input type="datetime-local"
                   name="Event.EndDateTime"
                   value="@end.ToString("yyyy-MM-ddTHH:mm")" />

            <hr />

            <h4>Schedule</h4>

            <div id="scheduleContainer">

                @if (Model.Schedule != null && Model.Schedule.Count > 0)
                {
                    for (int i = 0; i < Model.Schedule.Count; i++)
                    {
                        <div class="child-item schedule-item">

                            <input type="hidden" name="Schedule[@i].Id" value="@Model.Schedule[i].Id" />

                            <label>Title</label>
                            <input name="Schedule[@i].Title"
                                   value="@Model.Schedule[i].Title" />

                            <label>Description</label>
                            <input name="Schedule[@i].Description"
                                   value="@Model.Schedule[i].Description" />

                            <label>Start Time</label>
                            <input type="time"
                                   name="Schedule[@i].StartTime"
                                   value="@Model.Schedule[i].StartTime" />

                            <label>End Time</label>
                            <input type="time"
                                   name="Schedule[@i].EndTime"
                                   value="@Model.Schedule[i].EndTime" />

                            <button type="button" onclick="removeSchedule(this)">
                                Remove
                            </button>

                        </div>
                    }
                }

            </div>

            <button type="button"
                    class="mf-add-btn"
                    onclick="addSchedule()">
                + Add Schedule
            </button>

            <hr />

            <h4>Guests</h4>

            @if (ViewBag.AllUsers != null)
            {
                var users = ViewBag.AllUsers as List<ApplicationUser>;
                var selectedIds = ViewBag.SelectedUserIds as List<string> ?? new List<string>();

                foreach (var user in users)
                {
                    var selected = selectedIds.Contains(user.Id);

                    <div class="mf-checkbox-row">
                        <input type="checkbox"
                               name="GuestIds"
                               value="@user.Id"
                        @(selected ? "checked" : "") />

                        <label>
                            @user.FullName (@user.Email)
                        </label>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No users available</p>
            }

            <div class="mf-btn-row">

                <button type="button"
                        class="mf-btn-back"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="mf-btn-submit">
                    Save Changes
                </button>

            </div>

        </form>

    </div>
</div>

<script>
    function previewCover(event) {
        const file = event.target.files[0];
        const preview = document.getElementById("coverPreview");

        if (file) {
            preview.src = URL.createObjectURL(file);
            preview.style.display = "block";
        }
    }

    let scheduleIndex = @scheduleCount;

    function addSchedule() {
        const container = document.getElementById("scheduleContainer");

        const html = `
        <div class="child-item schedule-item">

            <input type="hidden" name="Schedule[${scheduleIndex}].Id" value="0" />

            <label>Title</label>
            <input name="Schedule[${scheduleIndex}].Title" />

            <label>Description</label>
            <input name="Schedule[${scheduleIndex}].Description" />

            <label>Start Time</label>
            <input type="time" name="Schedule[${scheduleIndex}].StartTime" />

            <label>End Time</label>
            <input type="time" name="Schedule[${scheduleIndex}].EndTime" />

            <button type="button" onclick="removeSchedule(this)">
                Remove
            </button>

        </div>`;

        container.insertAdjacentHTML("beforeend", html);
        scheduleIndex++;
    }

    function removeSchedule(btn) {
        btn.closest(".schedule-item").remove();
    }

    $(document).on('submit', '#editDetailsForm', function (e) {
        e.preventDefault();
    

        var formData = new FormData(this);

        $.ajax({
            url: '/Event/EditDetails',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                if (res.success) {

                    // $('#pageLoader').fadeIn(150);

                    Toast.success("Event Details updated successfully", "Refreshing...");

                    var modalEl = document.getElementById('eventDetailsModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();

                    setTimeout(() => {
                        location.reload();
                    }, 2200);
                }
            },
            error: function (err) {
                Toast.error("Something went wrong!! ", "Try Again...");
            }
        });
    });
</script>