@model RegisterMemberDto

@{
    Layout = null;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<div class="mf-page">

    <div class="mf-card">

        <div class="mf-heading">
            Add Member
        </div>

        <div class="mf-subtitle">
            Enter member details to create a new account
        </div>

        <form id="registerMemberForm">

            <div class="mf-grid-2">
                <div>
                    <label>First Name</label>
                    <input name="FirstName" class="form-control" placeholder="First Name" />
                    <span class="field-error"></span>
                </div>

                <div>
                    <label>Middle Name</label>
                    <input name="MiddleName" class="form-control" placeholder="Middle Name" />
                </div>
            </div>

            <div class="mf-grid-2">
                <div>
                    <label>Last Name</label>
                    <input name="LastName" class="form-control" placeholder="Last Name" />
                    <span class="field-error"></span>
                </div>

                <div>
                    <label>EO Role</label>
                    <input name="EoRole" class="form-control" placeholder="EO Role" />
                    <span class="field-error"></span>
                </div>
            </div>

            <label>Gender</label>
            <select name="Gender" class="form-control" required>
                <option value="">-- Select Gender --</option>

                @foreach (EO.Models.Enums.Gender g in Enum.GetValues(typeof(EO.Models.Enums.Gender)))
                {
                    <option value="@((int)g)">@g</option>
                }
            </select>
            <span class="field-error"></span>

            <label>Email</label>
            <input name="Email" class="form-control" placeholder="name@example.com" />
            <span class="field-error"></span>

            <label>Mobile Number</label>
            <input name="MobileNumber" class="form-control" placeholder="Mobile Number" />
            <span class="field-error"></span>

            <div class="mf-grid-2">
                <div>
                    <label>Password</label>
                    <input name="Password" type="password" class="form-control" placeholder="Password" />
                    <span class="field-error"></span>
                </div>

                <div>
                    <label>Confirm Password</label>
                    <input name="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                    <span class="field-error"></span>
                </div>
            </div>

            <div class="mf-btn-row mt-3">

                <button type="button"
                        class="mf-btn-back"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="mf-btn-submit">
                    Create Member
                </button>

            </div>

        </form>

    </div>

</div>