

@{
    ViewData["Title"] = "Member Details";
}

@model EO.Models.MemberDetailDto

<link href="~/css/memeberDetail.css" rel="stylesheet" />

<div class="profile-dashboard">
    <div class="row g-0">
        <div class="col-md-3 profile-sidebar">
            <div class="sidebar-content">
                <div class="profile-image-container">
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="@Model.ProfileImage" alt="@Model.Name" />
                    }
                    else
                    {
                        <div class="photo-placeholder">@Model.Name?.Substring(0, 1)</div>
                    }
                </div>

                <div class="sidebar-section">
                    <h6 class="sidebar-label">WORK</h6>
                    <div class="work-entry">
                        <span class="company-name">@Model.CompanyName</span>
                        <span class="tag-blue">Primary</span>
                    </div>
                </div>

                <hr class="sidebar-divider" />

                <div class="sidebar-section">
                    <h6 class="sidebar-label">SKILLS</h6>
                    <ul class="skills-list">
                        @if (Model.Spouse?.Professional?.Expertise != null)
                        {
                            @foreach (var rawSkill in Model.Spouse.Professional.Expertise)
                            {
                                var cleanSkill = rawSkill.Replace("\"", "").Replace("[", "").Replace("]", "").Trim();
                                if (!string.IsNullOrWhiteSpace(cleanSkill))
                                {
                                    <li>@cleanSkill</li>
                                }
                            }
                        }
                        else
                        {
                            <li>Strategy</li>
                            <li>Project Management</li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-9 profile-main">
            <div class="main-header">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h1 class="user-name">@Model.Name <span class="location-text"><i class="fa-solid fa-location-dot"></i> @Model.Location</span></h1>
                        <p class="user-subtitle">@Model.EoRole</p>
                    </div>
                    <div class="ratings-section">
                        <span class="rating-score">8.6</span>
                        <div class="stars">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-regular fa-star"></i>
                        </div>
                    </div>
                </div>

                <div class="profile-tabs mt-4">
                    <button class="tab-item active" onclick="switchTab(event, 'personal')">Personal</button>
                    <button class="tab-item" onclick="switchTab(event, 'company')">Company</button>
                    <button class="tab-item" onclick="switchTab(event, 'social')">Social</button>
                    <button class="tab-item" onclick="switchTab(event, 'spouse')">Spouse</button>
                    <button class="tab-item" onclick="switchTab(event, 'children')">Children</button>
                </div>
            </div>

            <div class="tab-content-area">
                
                <section id="personal" class="info-pane active">
                    <h5 class="section-heading">Contact Information</h5>
                    <div class="info-row"><div class="info-label">Phone:</div><div class="info-value link-style">@Model.Phone</div></div>
                    <div class="info-row"><div class="info-label">Email:</div><div class="info-value link-style">@Model.Email</div></div>
                    
                    <h5 class="section-heading mt-4">Basic Information</h5>
                    <div class="info-row"><div class="info-label">Birthday:</div><div class="info-value">@Model.Dob?.ToString("MMMM dd, yyyy")</div></div>
                    <div class="info-row"><div class="info-label">Gender:</div><div class="info-value">Male</div></div>
                </section>

                <section id="company" class="info-pane">
                    <h5 class="section-heading">Professional Details</h5>
                    <div class="info-row"><div class="info-label">Company:</div><div class="info-value">@Model.CompanyName</div></div>
                    <div class="info-row"><div class="info-label">Role:</div><div class="info-value">@Model.CompanyRole</div></div>
                    <div class="info-row"><div class="info-label">Designation:</div><div class="info-value">@Model.Designation</div></div>
                </section>

                <section id="social" class="info-pane">
                    <h5 class="section-heading">Social Presence</h5>
                    <div class="info-row"><div class="info-label">LinkedIn:</div><div class="info-value link-style">@Model.SocialLinks?.Linkedin</div></div>
                    <div class="info-row"><div class="info-label">Website:</div><div class="info-value link-style">@Model.SocialLinks?.Website</div></div>
                    <div class="info-row"><div class="info-label">Twitter:</div><div class="info-value link-style">@Model.SocialLinks?.Twitter</div></div>
                </section>

                <section id="spouse" class="info-pane">
                    @if (Model.Spouse != null) {
                        <h5 class="section-heading">Spouse Information</h5>
                        <div class="info-row"><div class="info-label">Name:</div><div class="info-value">@Model.Spouse.Name</div></div>
                        <div class="info-row"><div class="info-label">Profession:</div><div class="info-value">@Model.Spouse.Professional?.Position</div></div>
                    } else { <p class="text-muted">No spouse data available.</p> }
                </section>

                <section id="children" class="info-pane">
                    <h5 class="section-heading">Children</h5>
                    @if (Model.Children?.Any() == true) {
                        @foreach (var child in Model.Children) {
                            <div class="info-row mb-3"><div class="info-label">@child.Name:</div><div class="info-value">@child.School (Grade @child.Grade)</div></div>
                        }
                    } else { <p class="text-muted">No children data available.</p> }
                </section>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(evt, tabName) {
        var i, tabContent, tabLinks;
        tabContent = document.getElementsByClassName("info-pane");
        for (i = 0; i < tabContent.length; i++) { tabContent[i].classList.remove("active"); }
        tabLinks = document.getElementsByClassName("tab-item");
        for (i = 0; i < tabLinks.length; i++) { tabLinks[i].classList.remove("active"); }
        document.getElementById(tabName).classList.add("active");
        evt.currentTarget.classList.add("active");
    }
</script>