@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EO</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

  <style>
    /* 1. Theme Variable Definitions */
    :root {
        /* Light Theme (Default) */
        --app-bg: #F8F9FA;
        --sidebar-bg: #FFFFFF;
        --sidebar-hover-bg: #F1F3F5;
        --sidebar-active-bg: #E9ECEF;
        --sidebar-text: #495057;
        --sidebar-text-hover: #000000;
        --sidebar-title-color: #ADB5BD;
        --border-color: #DEE2E6;
        --main-text: #212529;
    }

    [data-theme='dark'] {
        /* Dark Theme (Your #0B0C0D palette) */
        --app-bg: #121212;
        --sidebar-bg: #0B0C0D;
        --sidebar-hover-bg: #1A1C1E;
        --sidebar-active-bg: #242729;
        --sidebar-text: #ADB5BD;
        --sidebar-text-hover: #FFFFFF;
        --sidebar-title-color: #6C757D;
        --border-color: #222426;
        --main-text: #E9ECEF;
    }

    /* 2. Global Resets */
    html, body {
        height: 100%;
        margin: 0;
        color: var(--main-text);
        background-color: var(--app-bg);
        transition: background-color 0.3s ease;
    }

    /* 3. Layout */
    .app-layout {
        display: flex;
        min-height: calc(100vh - 56px); 
        background-color: var(--app-bg);
    }

    /* 4. Sidebar Styling */
    .sidebar {
        width: 260px;
        background-color: var(--sidebar-bg);
        border-right: 1px solid var(--border-color);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        z-index: 1000;
    }

    .sidebar.collapsed {
        width: 70px;
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 18px;
        height: 64px;
    }

    .sidebar-title {
        font-size: 11px;
        font-weight: 700;
        color: var(--sidebar-title-color);
        text-transform: uppercase;
        letter-spacing: 1.2px;
    }

    .toggle-btn {
        cursor: pointer;
        color: var(--sidebar-text);
        font-size: 20px;
        transition: color 0.2s;
    }

    .toggle-btn:hover {
        color: var(--sidebar-text-hover);
    }

    /* 5. Navigation Links */
    .sidebar a {
        display: flex;
        align-items: center;
        padding: 12px 18px;
        text-decoration: none;
        color: var(--sidebar-text);
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.2s;
        margin: 4px 8px;
        border-radius: 8px;
    }

    .sidebar a i {
        font-size: 1.2rem;
        min-width: 35px;
    }

    .sidebar a:hover {
        background-color: var(--sidebar-hover-bg);
        color: var(--sidebar-text-hover);
    }

    .sidebar a.active {
        background-color: var(--sidebar-active-bg);
        color: var(--sidebar-text-hover);
        font-weight: 600;
    }

    /* 6. Collapsed Logic */
    .sidebar.collapsed .text,
    .sidebar.collapsed .sidebar-title {
        display: none;
    }

    .sidebar.collapsed a {
        justify-content: center;
        margin: 4px 10px;
        padding: 12px 0;
    }

    .sidebar.collapsed a i {
        min-width: unset;
        margin: 0;
    }

    /* 7. Main Content & Navbar */
    .main-content {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        color: var(--main-text);
    }

    .navbarBackground {
        background-color: var(--sidebar-bg) !important; /* Forces top nav to match sidebar */
        border-bottom: 1px solid var(--border-color) !important;
    }
    
    /* Ensure Top Nav links also adapt */
    .navbarBackground .nav-link {
        color: var(--sidebar-text) !important;
    }

    .navbarBackground .nav-link:hover {
        color: var(--sidebar-text-hover) !important;
    }
</style>


    <script>
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm   border-bottom box-shadow topbar navbarBackground mx-3" >
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">EO</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>`
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <!-- <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li> -->
                    </ul>

                    <button class="btn btn-link text-decoration-none p-0 me-3" onclick="toggleTheme()" id="themeToggleBtn" style="font-size: 1.25rem; color: inherit;">
                        <span id="themeIcon">🌙</span>
                    </button>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="app-layout">

        @if (User.Identity.IsAuthenticated)
        {
            <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-title">Entrepreneur's Organization</div>
        <div class="toggle-btn" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </div>
    </div>

    <nav class="flex-column">
        <a asp-controller="Home" asp-action="Index" class="@(@controller == "Home" ? "active" : "")">
            <i class="bi bi-house-door"></i>
            <span class="text">Home</span>
        </a>

        @if (User.IsInRole("SuperAdmin"))
        {
            <a asp-controller="Profile" asp-action="Members" class="@(@controller == "Profile" || @controller == "Members" ? "active" : "")">
                <i class="bi bi-people"></i>
                <span class="text">Members</span>
            </a>
            
            <a asp-controller="Event" asp-action="Index" class="@(@controller == "Event" ? "active" : "")">
                <i class="bi bi-calendar-event"></i>
                <span class="text">Events</span>
            </a>
            
            <a asp-controller="Alliance" asp-action="Index" class="@(@controller == "Alliance" ? "active" : "")">
                <i class="bi bi-shield-check"></i>
                <span class="text">Alliances</span>
            </a>
        }
    </nav>
</aside>
        }

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <!-- <footer class="border-top footer text-muted bg-white">
        <div class="container py-3">
            &copy; 2026 - EO - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/modal.js"></script>

    <script>
            function toggleSidebar() {
                document.getElementById("sidebar").classList.toggle("collapsed");
            }
            

            function toggleTheme() {
                const html = document.documentElement;
                const currentTheme = html.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                
                updateThemeIcon(newTheme);
            }

            function updateThemeIcon(theme) {
                const icon = document.getElementById('themeIcon');
                if (icon) {
                    icon.textContent = theme === 'dark' ? '☀️' : '🌙';
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
                updateThemeIcon(currentTheme);
            });
    </script>
    @Html.Partial("_CommonModal")
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>