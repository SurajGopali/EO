@model EO.Models.EventUpdateDto

@{
    Layout = null;

    var dateValue = Model.Date == default
        ? DateTime.Today
        : Model.Date;

    var isEdit = Model.Id > 0;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<div class="mf-page">

    <div class="mf-card">

        <div class="mf-heading">
            @(isEdit ? "Edit Event" : "Add Event")
        </div>

        <div class="mf-subtitle">
            @(isEdit ? "Update your event details" : "Enter your event details")
        </div>

        <form id="eventForm" enctype="multipart/form-data">

            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="Image" value="@Model.Image" />

            <!-- TITLE -->
            <label>Title</label>
            <input name="Title" value="@Model.Title" class="form-control" />

            <!-- LOCATION -->
            <label>Location</label>
            <input name="Location" value="@Model.Location" class="form-control" />

            <!-- DESCRIPTION -->
            <label>Description</label>
            <textarea name="Description" class="form-control">@Model.Description</textarea>

            <!-- DATE + TIME ROW -->
            <div style="display:flex; gap:10px; flex-wrap:wrap;">

                <div style="flex:1;">
                    <label>Date</label>
                    <input type="date"
                           name="Date"
                           value="@dateValue.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div style="flex:1;">
                    <label>Start Time</label>
                    <input name="StartTime"
                           type="time"
                           value="@Model.StartTime"
                           class="form-control" />
                </div>

                <div style="flex:1;">
                    <label>End Time</label>
                    <input name="EndTime"
                           type="time"
                           value="@Model.EndTime"
                           class="form-control" />
                </div>

            </div>

            <!-- EVENT TYPE -->
            <label>Event Type</label>
            <select name="TypeId" class="form-control">
                <option value="">-- Select Event Type --</option>

                @foreach (var type in ViewBag.EventTypes)
                {
                    <option value="@type.Id"
                            selected="@(type.Id == Model.TypeId ? "selected" : null)">
                        @type.Name
                    </option>
                }
            </select>

            <!-- CURRENT IMAGE -->

            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <label>Current Image</label>

                <div style="margin-bottom:15px;">
                    <img id="preview"
                        src="@Model.Image"
                        style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                </div>
            }
                else
                {
                    <img id="preview"
                         style="display:none;width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                }   

            <!-- CHANGE IMAGE -->
            <label>Change Image</label>
            <input type="file"
                   name="ImageFile"
                   class="form-control"
                   onchange="previewImage(event)" />

            <!-- BUTTONS -->
            <div class="mf-btn-row mt-3">

                <button type="button"
                        class="mf-btn-back"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="mf-btn-submit">
                    Save
                </button>

            </div>

        </form>

    </div>

</div>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            preview.src = URL.createObjectURL(input.files[0]);
            preview.style.display = "block";
        }
    }

    $(document).on('submit', '#eventForm', function (e) {
        e.preventDefault();
         var isEdit = @(isEdit.ToString().ToLower());
        var formData = new FormData(this);

        $.ajax({
            url: '/Event/Edit',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,

            success: function (res) {
                if (res.success) {

                    // $('#pageLoader').fadeIn(150);

                    Toast.success("Event " + (isEdit ? "updated" : "added") + " successfully", "Refreshing...");

                    var modalEl = document.getElementById('eventModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();

                    setTimeout(() => {
                        location.reload();
                    }, 2200);
                }
            },

            error: function (err) {
                Toast.error("Something went wrong!! ", "Try Again...");
            }
        });
    });
</script>