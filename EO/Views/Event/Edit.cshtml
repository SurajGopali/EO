@model EO.Models.EventUpdateDto

@{
    ViewData["Title"] = Model.TypeId > 0 ? "Edit Event" : "Add Event";

    var dateValue = Model.Date == default
        ? DateTime.Today
        : Model.Date;

    var isEdit = Model.TypeId > 0;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<div class="mf-page">
    <div class="mf-card">

        <div class="mf-heading">
            @(isEdit ? "Edit Event" : "Add Event")
        </div>

        <div class="mf-subtitle">
            @(isEdit ? "Update your event information" : "Enter your event information")
        </div>

        <form asp-action="Edit"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden" asp-for="Image" />

            <!-- TITLE -->
            <label>Title</label>
            <input asp-for="Title" class="form-control" />

            <!-- DESCRIPTION -->
            <label>Description</label>
            <textarea asp-for="Description" class="form-control"></textarea>

            <!-- LOCATION -->
            <label>Location</label>
            <input asp-for="Location" class="form-control" />

            <!-- DATE -->
            <label>Date</label>
            <input type="date"
                   name="Date"
                   value="@dateValue.ToString("yyyy-MM-dd")"
                   class="form-control" />

            <!-- TIME -->
            <label>Start Time</label>
            <input asp-for="StartTime" type="time" class="form-control" />

            <label>End Time</label>
            <input asp-for="EndTime" type="time" class="form-control" />

            <!-- EVENT TYPE -->
            <label>Event Type</label>
            <select asp-for="TypeId" class="form-control">
                <option value="">-- Select Event Type --</option>

                @foreach (var type in ViewBag.EventTypes)
                {
                    <option value="@type.Id"
                            selected="@(type.Id == Model.TypeId ? "selected" : null)">
                        @type.Name
                    </option>
                }
            </select>

            <!-- IMAGE UPLOAD -->
            <label class="mt-3">Event Image</label>

            <input type="file"
                   name="ImageFile"
                   class="form-control"
                   onchange="previewImage(event)" />

            <!-- IMAGE PREVIEW -->
            <div style="margin-top:10px;">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img id="preview"
                         src="@Model.Image"
                         width="140"
                         style="border-radius:8px;" />
                }
                else
                {
                    <img id="preview"
                         style="display:none; width:140px; border-radius:8px;" />
                }
            </div>

            <!-- BUTTONS -->
            <div class="mf-btn-row mt-4">
                <a asp-action="Index"
                       class="mf-btn-back text-decoration-none">
                    Cancel
                </a>

                <button type="submit"
                        class="mf-btn-submit">
                    Save Changes
                </button>
            </div>

        </form>

    </div>
</div>

<script>
    function previewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            preview.src = URL.createObjectURL(input.files[0]);
            preview.style.display = "block";
        }
    }
</script>