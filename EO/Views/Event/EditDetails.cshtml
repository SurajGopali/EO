@model EO.Models.UpdateEventDetailFullDto

@{
    ViewData["Title"] = "Edit Event";

    var start = Model.Event.StartDateTime == default
        ? DateTime.Now
        : Model.Event.StartDateTime;

    var end = Model.Event.EndDateTime == default
        ? DateTime.Now
        : Model.Event.EndDateTime;
}

<div class="container mt-4">

    <div class="card p-4 shadow-sm">

        <h3 class="mb-3">Update Event</h3>

        <form asp-action="EditDetails" asp-route-id="@Model.EventId" method="post">

            <!-- =========================
                 EVENT DETAILS
            ========================== -->

            <h5 class="mb-3">Event Details</h5>

            <label>Title</label>
            <input class="form-control" asp-for="Event.Title" />

            <label>Description</label>
            <textarea class="form-control" asp-for="Event.Description"></textarea>

            <label>Venue</label>
            <input class="form-control" asp-for="Event.Venue" />

            <label>Cover Image</label>
            <input class="form-control" asp-for="Event.CoverImage" />

            <label>Start DateTime</label>
            <input type="datetime-local"
                   class="form-control"
                   name="Event.StartDateTime"
                   value="@start.ToString("yyyy-MM-ddTHH:mm")" />

            <label>End DateTime</label>
            <input type="datetime-local"
                   class="form-control"
                   name="Event.EndDateTime"
                   value="@end.ToString("yyyy-MM-ddTHH:mm")" />

            <hr />

            <!-- =========================
                 SCHEDULE
            ========================== -->

            <h5>Schedule</h5>

            @if (Model.Schedule != null && Model.Schedule.Count > 0)
            {
                for (int i = 0; i < Model.Schedule.Count; i++)
                {
                    <div class="border p-3 mb-2 rounded">

                        <input type="hidden" asp-for="Schedule[i].Id" />

                        <label>Title</label>
                        <input class="form-control" asp-for="Schedule[i].Title" />

                        <label>Description</label>
                        <input class="form-control" asp-for="Schedule[i].Description" />

                        <label>Start Time</label>
                        <input type="time" class="form-control" asp-for="Schedule[i].StartTime" />

                        <label>End Time</label>
                        <input type="time" class="form-control" asp-for="Schedule[i].EndTime" />

                    </div>
                }
            }
            else
            {
                <p class="text-muted">No schedules</p>
            }

            <hr />

            <!-- =========================
                 GUESTS
            ========================== -->

            <h5>Guests</h5>

            @if (ViewBag.AllGuests != null && ((List<EO.Models.Guests>)ViewBag.AllGuests).Any())
            {
                var selectedIds = ViewBag.SelectedGuestIds as List<int> ?? new List<int>();

                foreach (var guest in ViewBag.AllGuests)
                {
                    var selected = selectedIds.Contains(guest.Id);

                    <div class="form-check">
                        <input type="checkbox"
                               class="form-check-input"
                               name="GuestIds"
                               value="@guest.Id"
                        @(selected ? "checked" : "") />

                        <label class="form-check-label">
                            @guest.Name (@guest.Designation)
                        </label>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No guests available</p>
            }

            <br />

            <button type="submit" class="btn btn-primary">
                Save Changes
            </button>

            <a asp-action="Details"
                   asp-route-id="@Model.EventId"
                   class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>