@model List<EventDto>

@{
    ViewData["Title"] = "Events";
}

<style>
    .event-container {
        background: #ffffff;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .event-table {
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .event-table thead th {
        border: none;
        font-size: 13px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .event-row {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.05);
        transition: 0.2s;
    }

    .event-row:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    .event-row td {
        border-top: none !important;
        vertical-align: middle;
        padding: 15px;
    }

    .event-img {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        object-fit: cover;
    }

    .event-title {
        font-weight: 600;
        font-size: 15px;
        color: #111;
    }

    .event-desc {
        font-size: 12px;
        color: #777;
    }

    .badge-soft {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 500;
    }

    .badge-type {
        background: #eef2ff;
        color: #4f46e5;
    }

    .badge-warning-soft {
        background: #fff7ed;
        color: #ea580c;
    }

    .badge-success-soft {
        background: #ecfdf5;
        color: #059669;
    }

    .badge-danger-soft {
        background: #fef2f2;
        color: #dc2626;
    }

    .badge-muted {
        background: #f3f4f6;
        color: #6b7280;
    }

    .event-actions button {
        border: none;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 12px;
        margin-right: 5px;
        cursor: pointer;
    }

    .btn-view {
        background: #e0f2fe;
        color: #0284c7;
    }

    .btn-edit {
        background: #fef3c7;
        color: #d97706;
    }
</style>

<h3 class="mb-3">Events</h3>

<div class="mb-3">
    <a asp-controller="Event"
           asp-action="Edit"
           asp-route-id="0"
           class="btn btn-success">
        + Add Event
    </a>
</div>

<div class="event-container">
    <table class="table event-table">
        <thead>
            <tr>
                <th></th>
                <th>Event</th>
                <th>Date</th>
                <th>Time</th>
                <th>Location</th>
                <th>Type</th>
                <th>Status</th>
                <th>Remaining</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var e in Model)
                {
                    <tr class="event-row">
                        <td>
                            @if (!string.IsNullOrEmpty(e.Image))
                            {
                                <img src="@e.Image" class="event-img" />
                            }
                        </td>

                        <td>
                            <div class="event-title">@e.Title</div>
                            <div class="event-desc">@e.Description</div>
                        </td>

                        <td>@e.Date.ToString("MMM dd, yyyy")</td>

                        <td>
                            @(e.StartTime?.ToString(@"hh\:mm") ?? "-")
                            -
                            @(e.EndTime?.ToString(@"hh\:mm") ?? "-")
                        </td>

                        <td>@e.Location</td>

                        <td>
                            <span class="badge-soft badge-type">
                                @e.Type
                            </span>
                        </td>

                        <td>
                            @if (e.IsRegistered == true)
                            {
                                <span class="badge-soft badge-success-soft">
                                    Registered
                                </span>
                            }
                            else
                            {
                                <span class="badge-soft badge-danger-soft">
                                    Not Registered
                                </span>
                            }
                        </td>

                        <td>
                            @if (e.RemainingDays > 0)
                            {
                                <span class="badge-soft badge-warning-soft">
                                    @e.RemainingDays days
                                </span>
                            }
                            else
                            {
                                <span class="badge-soft badge-muted">
                                    Started
                                </span>
                            }
                        </td>

                        <td class="event-actions">
                            <a class="btn-view"
                                   asp-controller="Event"
                                   asp-action="Details"
                                   asp-route-id="@e.Id">
                                View
                            </a>

                            <a class="btn-edit"
                                   asp-controller="Event"
                                   asp-action="Edit"
                                   asp-route-id="@e.Id">
                                Edit
                            </a>

                            <form asp-controller="Event"
                                  asp-action="Delete"
                                  asp-route-id="@e.Id"
                                  method="post"
                                  style="display:inline"
                                  onsubmit="return confirm('Are you sure you want to delete this event?');">

                                <button type="submit" class="btn btn-sm btn-danger">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center text-muted py-4">
                        No events found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>