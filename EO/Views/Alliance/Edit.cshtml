@model EO.Models.AllianceDto

@{
    ViewData["Title"] = Model.Id > 0 ? "Edit Alliance" : "Add Alliance";

    var types = ViewBag.Types as List<EO.Models.AllianceType>;
    var perks = ViewBag.Perks as List<EO.Models.Perk>;

    var selectedPerks = Model.PerkIds ?? new List<int>();
    var isEdit = Model.Id > 0;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<div class="mf-page">

    <div class="mf-card">

        <div class="mf-heading">@(isEdit ? "Edit Alliance" : "Add Alliance")</div>
        <div class="mf-subtitle">
            @(isEdit ? "Update your alliance information" : "Enter your alliance information")
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <label>Name</label>
            <input asp-for="Name" />

            <label>Description</label>
            <textarea asp-for="Description"></textarea>

            <label>Alliance Type</label>
            <select asp-for="AllianceTypeId">
                <option value="">-- Select Type --</option>

                @foreach (var t in types)
                {
                    <option value="@t.Id"
                            selected="@(t.Id == Model.AllianceTypeId ? "selected" : null)">
                        @t.Name
                    </option>
                }
            </select>

            <label>Current Logo</label>

            <div style="margin-bottom:15px;">
                @if (!string.IsNullOrEmpty(Model.Logo))
                {
                    <img src="@Url.Content(Model.Logo)"
                         style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                }
                else
                {
                    <img src="/images/default.png"
                         style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                }
            </div>

            <label>Change Logo</label>
            <input asp-for="LogoFile"
                   type="file"
                   accept="image/*" />

            <label>Perks</label>

            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:18px;">
                @foreach (var p in perks)
                {
                    <label style="padding:8px 14px;border:1px solid #d8d8d8;border-radius:10px;cursor:pointer;">
                        <input type="checkbox"
                               name="PerkIds"
                               value="@p.Id"
                               @(selectedPerks.Contains(p.Id) ? "checked" : "") />
                        @p.Name
                    </label>
                }
            </div>

            <div class="mf-btn-row">

                <a asp-action="Index"
                   class="mf-btn-back text-decoration-none">
                    Cancel
                </a>

                <button type="submit" class="mf-btn-submit">
                    @(isEdit ? "Save Changes" : "Create Alliance")
                </button>

            </div>

        </form>

    </div>

</div>