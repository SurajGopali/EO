@model EO.Models.AllianceDto

@{
    var types = ViewBag.Types as List<AllianceType>;
    var perks = ViewBag.Perks as List<Perk>;

    var selectedPerks = Model.PerkIds ?? new List<int>();
    var isEdit = Model.Id > 0;
}

<link href="~/css/memberSetup.css" rel="stylesheet" />

<div class="mf-page">

    <div class="mf-card">

        <div class="mf-heading">
            @(isEdit ? "Edit Alliance" : "Add Alliance")
        </div>

        <div class="mf-subtitle">
            @(isEdit ? "Update your alliance information" : "Enter your alliance information")
        </div>

        <form id="allianceForm" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <label>Name</label>
            <input asp-for="Name" class="form-control" />

            <label>Description</label>
            <textarea asp-for="Description" class="form-control"></textarea>

            <label>Alliance Type</label>
            <select asp-for="AllianceTypeId" class="form-control">
                <option value="">-- Select Type --</option>
                @foreach (var t in types)
                {
                    <option value="@t.Id"
                            selected="@(t.Id == Model.AllianceTypeId ? "selected" : null)">
                        @t.Name
                    </option>
                }
            </select>

            <label>Current Logo</label>

            <div style="margin-bottom:15px;">
                @if (!string.IsNullOrEmpty(Model.Logo))
                {
                    <img src="@Model.Logo"
                         style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                }
                else
                {
                    <img src="/images/default.png"
                         style="width:120px;height:120px;object-fit:cover;border-radius:12px;border:1px solid #ddd;" />
                }
            </div>

            <label>Change Logo</label>
            <input asp-for="LogoFile" type="file" class="form-control" />

            <hr />

            <label>Perks</label>

            <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:10px;">
                @foreach (var p in perks)
                {
                    <label style="padding:8px 12px;border:1px solid #ddd;border-radius:10px;cursor:pointer;">
                        <input type="checkbox"
                               name="PerkIds"
                               value="@p.Id"
                        @(selectedPerks.Contains(p.Id) ? "checked" : "") />
                        @p.Name
                    </label>
                }
            </div>

            <div class="mf-btn-row mt-3">

                <button type="button"
                        class="mf-btn-back"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="mf-btn-submit">
                    Save Changes
                </button>

            </div>

        </form>

    </div>

</div>

<script>
        $(document).on('submit', '#allianceForm', function (e) {
        e.preventDefault();

        var formData = new FormData(this);

        $.ajax({
            url: '/Alliance/Upsert',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {

                if (res.success) {

                    var modalEl = document.getElementById('allianceModal');
                    var modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();

                    location.reload();
                }
            }
        });
    });
</script>