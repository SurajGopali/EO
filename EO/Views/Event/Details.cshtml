@model EO.Models.EventDetailsDto

@{
    ViewData["Title"] = "Event Details";
}

<link href="~/css/memeberDetail.css" rel="stylesheet" />

<div class="profile-dashboard">
    <div class="row g-0">

        <!-- SIDEBAR -->
        <div class="col-md-3 profile-sidebar">
            <div class="sidebar-content">

                <div class="profile-image-container">
                    @if (!string.IsNullOrEmpty(Model.CoverImage))
                    {
                        <img src="@Model.CoverImage" alt="@Model.Title" />
                    }
                    else
                    {
                        <div class="photo-placeholder">@Model.Title?.Substring(0,1)</div>
                    }
                </div>

                <div class="sidebar-section">
                    <h6 class="sidebar-label">VENUE</h6>
                    <div class="work-entry">
                        <span class="company-name">@Model.Venue</span>
                        @if (Model.IsRegistered)
                        {
                            <span class="tag-blue">Registered</span>
                        }
                        else
                        {
                            <span class="tag-blue">Open</span>
                        }
                    </div>
                </div>

                <hr class="sidebar-divider" />

                <div class="sidebar-section">
                    <h6 class="sidebar-label">TIMING</h6>
                    <ul class="skills-list">
                        <li>@Model.StartDateTime.ToString("MMM dd, yyyy")</li>
                        <li>@Model.StartDateTime.ToString("hh:mm tt")</li>
                        <li>@Model.EndDateTime.ToString("hh:mm tt")</li>
                    </ul>
                </div>

            </div>
        </div>

        <!-- MAIN -->
        <div class="col-md-9 profile-main">

            <div class="main-header">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h1 class="user-name">
                            @Model.Title
                            <span class="location-text">
                                <i class="fa-solid fa-location-dot"></i> @Model.Venue
                            </span>
                        </h1>
                        <p class="user-subtitle">@Model.Description</p>
                    </div>

                    <div>
                        <a class="btn btn-warning btn-sm"
                           asp-controller="Event"
                           asp-action="EditDetails"
                           asp-route-id="@Model.Id">
                            Update Event Details
                        </a>
                    </div>
                </div>

                <div class="profile-tabs mt-4">
                    <button class="tab-item active" onclick="switchTab(event,'overview')">Overview</button>
                    <button class="tab-item" onclick="switchTab(event,'schedule')">Schedule</button>
                    <button class="tab-item" onclick="switchTab(event,'guests')">Guests</button>
                </div>
            </div>

            <div class="tab-content-area">

                <!-- OVERVIEW -->
                <section id="overview" class="info-pane active">
                    <h5 class="section-heading">Event Information</h5>

                    <div class="info-row">
                        <div class="info-label">Title:</div>
                        <div class="info-value">@Model.Title</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Venue:</div>
                        <div class="info-value">@Model.Venue</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Start:</div>
                        <div class="info-value">@Model.StartDateTime.ToString("MMMM dd, yyyy hh:mm tt")</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">End:</div>
                        <div class="info-value">@Model.EndDateTime.ToString("MMMM dd, yyyy hh:mm tt")</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Status:</div>
                        <div class="info-value">
                            @(Model.IsRegistered ? "Registered" : "Not Registered")
                        </div>
                    </div>
                </section>

                <!-- SCHEDULE -->
                <section id="schedule" class="info-pane">
                    <h5 class="section-heading">Schedule</h5>

                    @if (Model.Schedule?.Any() == true)
                    {
                        @foreach (var s in Model.Schedule)
                        {
                            <div class="info-row mb-3">
                                <div class="info-label">@s.Title</div>
                                <div class="info-value">
                                    @s.StartTime - @s.EndTime <br />
                                    @s.Description
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No schedule available.</p>
                    }
                </section>

                <!-- GUESTS -->
                <section id="guests" class="info-pane">
                    <h5 class="section-heading">Guests</h5>

                    @if (Model.Guests?.Any() == true)
                    {
                        @foreach (var g in Model.Guests)
                        {
                            <div class="info-row mb-3">
                                <div class="info-label">@g.Name</div>
                                <div class="info-value">@g.Designation</div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No guests available.</p>
                    }
                </section>

            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(evt, tabName) {
        var i, tabContent, tabLinks;

        tabContent = document.getElementsByClassName("info-pane");
        for (i = 0; i < tabContent.length; i++) {
            tabContent[i].classList.remove("active");
        }

        tabLinks = document.getElementsByClassName("tab-item");
        for (i = 0; i < tabLinks.length; i++) {
            tabLinks[i].classList.remove("active");
        }

        document.getElementById(tabName).classList.add("active");
        evt.currentTarget.classList.add("active");
    }
</script>